<view class="container" wx:if="{{tool}}">
  <view class="hero direct-hero" style="background: {{tool.heroBackground}};">
    <view class="hero-left">
      <text class="hero-title">{{tool.name}}</text>
      <text class="hero-cost">{{tool.points === 0 ? '免费' : (billing ? billing.costText : tool.points + ' 积分')}}</text>
    </view>
    <view class="hero-right" wx:if="{{userState}}">
      <view class="user-info">
        <text class="user-info__label">积分</text>
        <text class="user-info__value">{{userState.points}}</text>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{visibleParams && visibleParams.length > 0}}">
    <view class="section-head">
      <view>
        <text class="eyebrow">Setup</text>
        <text class="section-title">参数</text>
      </view>
    </view>

    <view class="card upload-card">
      <view class="option-block" wx:for="{{visibleParams}}" wx:key="key">
        <text class="option-block__title">{{item.label}}</text>
        <view class="chips-wrap {{showMoreColors && item.key === 'background' ? 'chips-wrap-expanded' : ''}}">
          <!-- 音视频转换特殊处理：按音频/视频分类 -->
          <block wx:if="{{tool.id === 'audio-convert' && item.key === 'target'}}">
            <!-- 音频格式组 -->
            <view wx:if="{{audioConvertAudioFormats.length && (audioInputKind === 'audio' || audioInputKind === 'video')}}" class="format-group">
              <text class="format-group-label">🎵 音频格式</text>
              <view class="format-group-chips">
                <view
                  class="chip {{selections[item.key] === option ? 'chip-active' : ''}}"
                  wx:for="{{audioConvertAudioFormats}}"
                  wx:for-item="option"
                  wx:key="*this"
                  data-key="{{item.key}}"
                  data-value="{{option}}"
                  bindtap="handleOptionSelect"
                >
                  <text>{{option}}</text>
                </view>
              </view>
            </view>
            <!-- 视频格式组 -->
            <view wx:if="{{audioConvertVideoFormats.length && audioInputKind === 'video'}}" class="format-group">
              <text class="format-group-label">🎬 视频格式</text>
              <view class="format-group-chips">
                <view
                  class="chip {{selections[item.key] === option ? 'chip-active' : ''}}"
                  wx:for="{{audioConvertVideoFormats}}"
                  wx:for-item="option"
                  wx:key="*this"
                  data-key="{{item.key}}"
                  data-value="{{option}}"
                  bindtap="handleOptionSelect"
                >
                  <text>{{option}}</text>
                </view>
              </view>
            </view>
          </block>
          <!-- 其他参数正常渲染 -->
          <block wx:else>
            <view
              class="chip {{selections[item.key] === option ? 'chip-active' : ''}} {{item.key === 'background' ? 'chip-color' : ''}}"
              wx:for="{{item.key === 'background' && !showMoreColors ? ['白色', '蓝色', '红色'] : (item.key === 'background' && showMoreColors ? tool.params[1].options : (tool.id === 'image-convert' && item.key === 'target' && imageInput ? convertTargetOptions : item.options))}}"
              wx:for-item="option"
              wx:key="*this"
              data-key="{{item.key}}"
              data-value="{{option}}"
              bindtap="handleOptionSelect"
            >
              <view wx:if="{{item.key === 'background'}}" class="chip-color__dot" style="background: {{backgroundColorMap[option]}};"></view>
              <text>{{option}}</text>
            </view>
            <view
              class="chip chip-expand {{showMoreColors ? 'chip-active' : ''}}"
              wx:if="{{item.key === 'background'}}"
              bindtap="toggleMoreColors"
            >
              <text>{{showMoreColors ? '收起' : '更多'}}</text>
            </view>
          </block>
        </view>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{showImageUpload && tool.id !== 'photo-id' && tool.id !== 'image-compress' && tool.id !== 'image-convert' && tool.id !== 'resize-crop'}}">
    <view class="section-head">
      <view>
        <text class="eyebrow">Upload</text>
        <text class="section-title">{{tool.id === 'ocr-text' ? (ocrResultReady ? '识别结果' : '上传识别图片') : '上传图片'}}</text>
        <text class="section-copy" wx:if="{{tool.id === 'ocr-text' && ocrResultReady}}">{{ocrResultDetail}}</text>
      </view>
    </view>

    <view class="card">
      <view class="btn-ghost picker-button" bindtap="chooseInputImage">{{tool.id === 'image-to-pdf' ? '选择图片（可多选）' : (tool.id === 'ocr-text' ? (ocrResultReady ? '重新选择图片' : '选择识别图片') : '选择图片')}}</view>

      <view class="image-preview" wx:if="{{imageInput && !(tool.id === 'ocr-text' && ocrResultReady) && tool.id !== 'image-to-pdf'}}">
        <image class="image-preview__image" src="{{imageInput.path}}" mode="aspectFit"></image>
        <text class="image-preview__meta">尺寸 {{imageInput.width}} × {{imageInput.height}}</text>
        <text class="image-preview__meta">大小 {{imageInput.sizeText}}</text>
      </view>

      <view class="ocr-result" wx:if="{{tool.id === 'ocr-text' && ocrResultReady}}">
        <view class="ocr-result__head">
          <view>
            <text class="result-card__title">{{ocrResultHeadline}}</text>
            <text class="ocr-result__meta">{{ocrResultLines.length}} 行 · {{ocrResultText.length}} 字 · {{ocrResultProviderText}}</text>
          </view>
          <view class="btn-ghost ocr-result__copy-all" bindtap="copyOcrAll">复制全部</view>
        </view>
        <scroll-view class="ocr-result__scroll" scroll-y>
          <view class="ocr-empty" wx:if="{{!ocrResultLines.length}}">
            <text>未识别到可展示的文字</text>
          </view>
          <view class="ocr-line" wx:for="{{ocrResultLines}}" wx:key="id">
            <text class="ocr-line__text" selectable="true" user-select="true">{{item.text}}</text>
            <view class="ocr-line__copy" data-text="{{item.text}}" bindtap="copyOcrLine">复制</view>
          </view>
        </scroll-view>
      </view>

      <view class="image-to-pdf-container" wx:if="{{tool.id === 'image-to-pdf' && imageInputs.length}}">
        <view class="image-to-pdf-header">
          <text class="image-preview__meta">已选择 {{imageInputs.length}} 张图片</text>
          <view class="image-to-pdf-delete-btn" data-index="{{imageToPdfCurrentIndex}}" bindtap="handleDeleteCurrentImage">
            <text class="image-to-pdf-delete-icon">✕</text>
          </view>
        </view>
        
        <!-- Swiper 大图预览 -->
        <swiper 
          class="image-to-pdf-swiper" 
          current="{{imageToPdfCurrentIndex}}" 
          bindchange="handleSwiperChange"
          indicator-dots="{{imageInputs.length > 1}}"
        >
          <swiper-item wx:for="{{imageInputs}}" wx:key="path">
            <image class="image-to-pdf-swiper__image" src="{{item.path}}" mode="aspectFit"></image>
          </swiper-item>
        </swiper>
        
        <!-- 缩略图列表 -->
        <scroll-view class="image-to-pdf-thumbs" scroll-x>
          <view class="image-to-pdf-thumbs__list">
            <view 
              class="image-to-pdf-thumb {{imageToPdfCurrentIndex === index ? 'image-to-pdf-thumb--active' : ''}} {{imageToPdfDraggingIndex === index ? 'image-to-pdf-thumb--dragging' : ''}} {{imageToPdfHighlightIndex === index && imageToPdfHighlightIndex !== imageToPdfDraggingIndex ? 'image-to-pdf-thumb--highlight' : ''}}"
              wx:for="{{imageInputs}}"
              wx:key="path"
              data-index="{{index}}"
              bindtap="handleThumbClick"
              bindtouchstart="handleImageToPdfThumbTouchStart"
              bindtouchmove="handleImageToPdfThumbTouchMove"
              bindtouchend="handleImageToPdfThumbTouchEnd"
            >
              <image class="image-to-pdf-thumb__image" src="{{item.path}}" mode="aspectFill"></image>
              <view class="image-to-pdf-thumb__index">{{index + 1}}</view>
              <view class="image-to-pdf-thumb__delete" data-index="{{index}}" catchtap="handleDeleteThumbImage">
                <text class="image-to-pdf-thumb__delete-icon">✕</text>
              </view>
            </view>
          </view>
        </scroll-view>

        <!-- 悬浮拖拽元素 -->
        <view 
          wx:if="{{imageToPdfDraggingIndex !== null}}" 
          class="image-to-pdf-floating-drag"
          style="left: {{imageToPdfFloatingLeft}}px; top: {{imageToPdfFloatingTop}}px;"
        >
          <image 
            class="image-to-pdf-floating-image" 
            src="{{imageInputs[imageToPdfDraggingIndex].path}}" 
            mode="aspectFill"
          ></image>
        </view>
      </view>
      
      <!-- PDF 结果展示 -->
      <view class="image-preview" wx:if="{{tool.id === 'image-to-pdf' && imageToPdfResultReady}}">
        <view class="file-preview">
          <text class="file-preview__icon">📄</text>
          <text class="file-preview__name">{{imageToPdfResultName}}</text>
        </view>
        <text class="result-card__title" style="margin-top: 16rpx; text-align: center;">{{imageToPdfResultHeadline}}</text>
        <view class="chips-wrap" wx:if="{{imageToPdfResultMetaLines.length}}" style="justify-content: center; margin-top: 12rpx;">
          <text class="chip-static" wx:for="{{imageToPdfResultMetaLines}}" wx:key="*this">{{item}}</text>
        </view>
        <view class="action-card__buttons" style="margin-top: 24rpx;">
          <view class="btn-primary action-card__button" bindtap="previewImageToPdfResult">预览 PDF</view>
          <view class="btn-primary action-card__button" bindtap="saveImageToPdfResult">保存 PDF</view>
          <view class="btn-ghost action-card__button" wx:if="{{imageToPdfResultRemoteUrl}}" bindtap="copyImageToPdfUrl">复制链接</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{tool.id === 'resize-crop'}}">
    <view class="section-head">
      <view>
        <text class="eyebrow">Upload</text>
        <text class="section-title">{{resizeResultReady ? '调整结果' : '上传图片'}}</text>
        <text class="section-copy" wx:if="{{resizeResultReady}}">{{resizeResultDetail}}</text>
      </view>
    </view>

    <view class="card">
      <view class="btn-ghost picker-button" bindtap="chooseInputImage" wx:if="{{!resizeResultReady}}">选择图片</view>
      <view class="btn-ghost picker-button" bindtap="chooseInputImage" wx:if="{{resizeResultReady}}">重新选择</view>

      <view class="image-preview" wx:if="{{imageInput && !resizeResultReady}}">
        <image class="image-preview__image" src="{{imageInput.path}}" mode="aspectFit"></image>
        <text class="image-preview__meta">尺寸 {{imageInput.width}} × {{imageInput.height}}</text>
        <text class="image-preview__meta">大小 {{imageInput.sizeText}}</text>
      </view>

      <view class="image-preview" wx:if="{{resizeResultReady}}">
        <image class="image-preview__image" src="{{resizeResultPath}}" mode="aspectFit"></image>
        <text class="result-card__title" style="margin-top: 16rpx; text-align: center;">{{resizeResultHeadline}}</text>
        <view class="chips-wrap" style="justify-content: center; margin-top: 12rpx;">
          <text class="chip-static">原尺寸 {{resizeBeforeWidth}} × {{resizeBeforeHeight}}</text>
          <text class="chip-static">新尺寸 {{resizeAfterWidth}} × {{resizeAfterHeight}}</text>
        </view>
        <view class="chips-wrap" wx:if="{{resizeResultMetaLines.length}}" style="justify-content: center; margin-top: 12rpx;">
          <text class="chip-static" wx:for="{{resizeResultMetaLines}}" wx:key="*this">{{item}}</text>
        </view>
        <view class="action-card__buttons" style="margin-top: 24rpx;">
          <view class="btn-primary action-card__button" bindtap="previewResizeResult">预览大图</view>
          <view class="btn-ghost action-card__button" bindtap="saveResizeResult">保存到相册</view>
          <view class="btn-ghost action-card__button" wx:if="{{resizeResultRemoteUrl}}" bindtap="copyResizeResultLink">复制链接</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{tool.id === 'image-compress'}}">
    <view class="section-head">
      <view>
        <text class="eyebrow">Upload</text>
        <text class="section-title">{{compressResultReady ? '压缩结果' : '上传图片'}}</text>
        <text class="section-copy" wx:if="{{compressResultReady}}">{{compressResultDetail}}</text>
      </view>
    </view>

    <view class="card">
      <view class="btn-ghost picker-button" bindtap="chooseInputImage" wx:if="{{!compressResultReady}}">选择图片</view>
      <view class="btn-ghost picker-button" bindtap="chooseInputImage" wx:if="{{compressResultReady}}">重新选择</view>

      <view class="image-preview" wx:if="{{imageInput && !compressResultReady}}">
        <image class="image-preview__image" src="{{imageInput.path}}" mode="aspectFit"></image>
        <text class="image-preview__meta">尺寸 {{imageInput.width}} × {{imageInput.height}}</text>
        <text class="image-preview__meta">大小 {{imageInput.sizeText}}</text>
      </view>

      <view class="image-preview" wx:if="{{compressResultReady}}">
        <image class="image-preview__image" src="{{compressResultPath}}" mode="aspectFit"></image>
        <text class="result-card__title" style="margin-top: 16rpx; text-align: center;">{{compressResultHeadline}}</text>
        <view class="chips-wrap" wx:if="{{compressResultMetaLines.length}}" style="justify-content: center; margin-top: 12rpx;">
          <text class="chip-static" wx:for="{{compressResultMetaLines}}" wx:key="*this">{{item}}</text>
        </view>
        <view class="action-card__buttons" style="margin-top: 24rpx;">
          <view class="btn-primary action-card__button" bindtap="previewCompressResult">预览大图</view>
          <view class="btn-ghost action-card__button" bindtap="saveCompressResult">保存到相册</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 万能压缩部分 -->
  <view class="section" wx:if="{{tool.id === 'universal-compress'}}">
    <view class="section-head">
      <view>
        <text class="eyebrow">Upload</text>
        <text class="section-title">{{universalCompressResultReady ? '压缩结果' : '选择文件'}}</text>
        <text class="section-copy" wx:if="{{universalCompressResultReady}}">{{universalCompressResultDetail}}</text>
      </view>
    </view>

    <view class="card">
      <!-- 选择文件按钮 -->
      <view class="btn-ghost picker-button" bindtap="chooseUniversalCompressFile" wx:if="{{!universalCompressResultReady}}">
        选择图片或文件
      </view>
      <view class="btn-ghost picker-button" bindtap="chooseUniversalCompressFile" wx:if="{{universalCompressResultReady}}">
        重新选择文件
      </view>

      <!-- 显示已选择的图片 -->
      <view class="image-preview" wx:if="{{imageInput && !universalCompressResultReady}}">
        <image class="image-preview__image" src="{{imageInput.path}}" mode="aspectFit"></image>
        <text class="image-preview__meta">尺寸 {{imageInput.width}} × {{imageInput.height}}</text>
        <text class="image-preview__meta">大小 {{imageInput.sizeText}}</text>
      </view>

      <!-- 显示已选择的文件 -->
      <view class="file-list" wx:if="{{backendFiles.length && !universalCompressResultReady}}">
        <view class="file-item" wx:for="{{backendFiles}}" wx:key="path">
          <text class="file-item__name">{{item.name}}</text>
          <text class="file-item__meta">{{item.sizeText}}</text>
        </view>
      </view>

      <!-- 显示压缩结果 -->
      <view class="image-preview" wx:if="{{universalCompressResultReady}}">
        <!-- 如果是图片显示预览 -->
        <image wx:if="{{universalCompressFileType === 'image'}}" class="image-preview__image" src="{{universalCompressResultPath}}" mode="aspectFit"></image>
        <!-- 如果是其他文件显示文件图标 -->
        <view wx:else class="file-preview">
          <text class="file-preview__icon">📄</text>
          <text class="file-preview__name">{{universalCompressResultName}}</text>
        </view>

        <text class="result-card__title" style="margin-top: 16rpx; text-align: center;">{{universalCompressResultHeadline}}</text>

        <view class="chips-wrap" style="justify-content: center; margin-top: 12rpx;">
          <text class="chip-static">原大小 {{universalCompressResultBeforeSizeText}}</text>
          <text class="chip-static">压缩后 {{universalCompressResultAfterSizeText}}</text>
          <text class="chip-static" wx:if="{{universalCompressResultSavedText}}">{{universalCompressResultSavedText}}</text>
        </view>

        <view class="chips-wrap" wx:if="{{universalCompressResultMetaLines.length}}" style="justify-content: center; margin-top: 12rpx;">
          <text class="chip-static" wx:for="{{universalCompressResultMetaLines}}" wx:key="*this">{{item}}</text>
        </view>

        <view class="action-card__buttons" style="margin-top: 24rpx;">
          <view class="btn-primary action-card__button" bindtap="previewUniversalCompressResult">预览</view>
          <view class="btn-ghost action-card__button" bindtap="saveUniversalCompressResult">保存</view>
          <view class="btn-ghost action-card__button" wx:if="{{universalCompressResultRemoteUrl}}" bindtap="copyUniversalCompressResultLink">复制链接</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{tool.id === 'image-convert'}}">
    <view class="section-head">
      <view>
        <text class="eyebrow">Upload</text>
        <text class="section-title">{{convertResultReady ? '转换结果' : '上传图片'}}</text>
        <text class="section-copy" wx:if="{{convertResultReady}}">{{convertResultDetail}}</text>
      </view>
    </view>

    <view class="card">
      <view class="btn-ghost picker-button" bindtap="chooseInputImage" wx:if="{{!convertResultReady}}">选择图片</view>
      <view class="btn-ghost picker-button" bindtap="chooseInputImage" wx:if="{{convertResultReady}}">重新选择</view>

      <view class="image-preview" wx:if="{{imageInput && !convertResultReady}}">
        <image class="image-preview__image" src="{{imageInput.path}}" mode="aspectFit"></image>
        <text class="image-preview__meta">尺寸 {{imageInput.width}} × {{imageInput.height}}</text>
        <text class="image-preview__meta">大小 {{imageInput.sizeText}}</text>
      </view>

      <view class="image-preview" wx:if="{{convertResultReady}}">
        <image class="image-preview__image" src="{{convertResultPath}}" mode="aspectFit"></image>
        <text class="result-card__title" style="margin-top: 16rpx; text-align: center;">{{convertResultHeadline}}</text>
        <view class="chips-wrap" wx:if="{{convertResultMetaLines.length}}" style="justify-content: center; margin-top: 12rpx;">
          <text class="chip-static" wx:for="{{convertResultMetaLines}}" wx:key="*this">{{item}}</text>
        </view>
        <view class="action-card__buttons" style="margin-top: 24rpx;">
          <view class="btn-primary action-card__button" bindtap="previewConvertResult">预览大图</view>
          <view class="btn-ghost action-card__button" bindtap="saveConvertResult">保存到相册</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{tool.id === 'photo-id'}}">
    <view class="section-head">
      <view>
        <text class="eyebrow">Upload</text>
        <text class="section-title">{{photoIdResultReady ? '生成结果' : '上传照片'}}</text>
        <text class="section-copy" wx:if="{{photoIdResultReady}}">{{photoIdResultDetail}}</text>
      </view>
    </view>

    <view class="card">
      <view class="btn-ghost picker-button" bindtap="chooseInputImage" wx:if="{{!photoIdResultReady}}">选择图片</view>
      <view class="btn-ghost picker-button" bindtap="chooseInputImage" wx:if="{{photoIdResultReady}}">重新选择</view>

      <view class="image-preview" wx:if="{{imageInput && !photoIdResultReady}}">
        <image class="image-preview__image" src="{{imageInput.path}}" mode="aspectFit"></image>
        <text class="image-preview__meta">尺寸 {{imageInput.width}} × {{imageInput.height}}</text>
        <text class="image-preview__meta">大小 {{imageInput.sizeText}}</text>
        <view class="cost-hint" wx:if="{{billing}}">
          <text class="cost-hint__text">{{billing.text}}</text>
        </view>
        
        <!-- 支付方式选择（积分足够时可选） -->
        <view class="payment-options" wx:if="{{billing && billing.mode === 'points'}}">
          <view 
            class="payment-option {{selectedPayment === 'points' ? 'selected' : ''}}"
            bindtap="selectPayment"
            data-type="points"
          >
            <view class="payment-option-icon">🎟️</view>
            <view class="payment-option-content">
              <text class="payment-option-title">使用积分</text>
              <text class="payment-option-desc">消耗 {{tool.points}} 积分（当前 {{userState.points}} 积分）</text>
            </view>
            <view class="payment-option-check">
              <view class="checkmark {{selectedPayment === 'points' ? 'checked' : ''}}"></view>
            </view>
          </view>
          
          <view 
            class="payment-option {{selectedPayment === 'direct' ? 'selected' : ''}}"
            bindtap="selectPayment"
            data-type="direct"
          >
            <view class="payment-option-icon">💳</view>
            <view class="payment-option-content">
              <text class="payment-option-title">直接支付</text>
              <text class="payment-option-desc">支付 ¥{{directPriceDisplay}}（{{tool.points}}积分等值）</text>
            </view>
            <view class="payment-option-check">
              <view class="checkmark {{selectedPayment === 'direct' ? 'checked' : ''}}"></view>
            </view>
          </view>
        </view>

        <!-- 积分不足提示 -->
        <view class="payment-locked-tip" wx:if="{{billing && billing.mode === 'locked'}}">
          <text class="payment-locked-text">积分不足，需支付 ¥{{directPriceDisplay}} 后使用</text>
        </view>
        
        <view class="action-card__buttons" style="margin-top: 16rpx;">
          <view class="btn-primary action-card__button {{!imageInput || isWorking ? 'action-card__button-disabled' : ''}}" bindtap="handleExecute">
            <view wx:if="{{isWorking}}" class="loading-wrap">
              <view class="loading-spinner">
                <view class="loading-dot"></view>
                <view class="loading-dot"></view>
                <view class="loading-dot"></view>
              </view>
              <text class="loading-text">处理中</text>
            </view>
            <text wx:else>{{primaryActionText}}</text>
          </view>
        </view>
      </view>

      <view class="image-preview" wx:if="{{photoIdResultReady}}">
        <image class="result-card__image" src="{{photoIdResultPath}}" mode="aspectFit" style="height: 420rpx;"></image>
        <text class="result-card__title" style="margin-top: 16rpx; text-align: center;">{{photoIdResultHeadline}}</text>
        <view class="chips-wrap" wx:if="{{photoIdResultMetaLines.length}}" style="justify-content: center; margin-top: 12rpx;">
          <text class="chip-static" wx:for="{{photoIdResultMetaLines}}" wx:key="*this">{{item}}</text>
        </view>
        <view class="action-card__buttons" style="margin-top: 24rpx;">
          <view class="btn-primary action-card__button" bindtap="previewPhotoIdResult">预览大图</view>
          <view class="btn-ghost action-card__button" bindtap="savePhotoIdResult">保存到相册</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{showBackendFilePicker}}">
    <view class="section-head">
      <view>
        <text class="eyebrow">Files</text>
        <text class="section-title">{{pdfToWordResultReady || audioConvertResultReady || officeToPdfResultReady ? '转换结果' : backendPickerTitle}}</text>
        <text class="section-copy" wx:if="{{pdfToWordResultReady}}">{{pdfToWordResultDetail}}</text>
        <text class="section-copy" wx:if="{{audioConvertResultReady}}">{{audioConvertResultDetail}}</text>
        <text class="section-copy" wx:if="{{officeToPdfResultReady}}">{{officeToPdfResultDetail}}</text>
      </view>
    </view>

    <view class="card">
      <view class="btn-ghost picker-button" bindtap="chooseBackendFiles" wx:if="{{!pdfToWordResultReady && !audioConvertResultReady && !pdfMergeResultReady && !officeToPdfResultReady}}">{{backendPickerButtonText}}</view>
      <view class="btn-ghost picker-button" bindtap="chooseBackendFiles" wx:if="{{pdfToWordResultReady || audioConvertResultReady || pdfMergeResultReady || officeToPdfResultReady}}">重新选择</view>

      <!-- PDF合并专用预览和排序UI -->
      <view class="pdf-merge-container" wx:if="{{tool.id === 'pdf-merge' && pdfMergePreviewFiles.length && !pdfMergeResultReady}}">
        <view class="pdf-merge-header">
          <text class="pdf-merge-title">已选择 {{pdfMergePreviewFiles.length}} 个PDF</text>
        </view>

        <!-- Swiper 大图预览 -->
        <swiper 
          class="pdf-merge-swiper" 
          current="{{pdfMergeCurrentIndex}}" 
          bindchange="handlePdfMergeSwiperChange"
          indicator-dots="{{pdfMergePreviewFiles.length > 1}}"
        >
          <swiper-item wx:for="{{pdfMergePreviewFiles}}" wx:key="path">
            <view class="pdf-preview-card">
              <text class="pdf-icon">📄</text>
              <view class="pdf-info">
                <text class="pdf-name">{{item.name}}</text>
                <text class="pdf-meta">{{item.sizeText}}{{item.pageCount > 0 ? ' · ' + item.pageCount + '页' : ''}}</text>
              </view>
            </view>
          </swiper-item>
        </swiper>

        <!-- 缩略图列表 -->
        <scroll-view class="pdf-merge-thumbs" scroll-x>
          <view class="pdf-merge-thumbs__list">
            <view 
              class="pdf-merge-thumb {{pdfMergeCurrentIndex === index ? 'pdf-merge-thumb--active' : ''}} {{pdfMergeDraggingIndex === index ? 'pdf-merge-thumb--dragging' : ''}} {{pdfMergeHighlightIndex === index && pdfMergeHighlightIndex !== pdfMergeDraggingIndex ? 'pdf-merge-thumb--highlight' : ''}}"
              wx:for="{{pdfMergePreviewFiles}}"
              wx:key="path"
              data-index="{{index}}"
              bindtap="handleThumbClick"
              bindtouchstart="handlePdfMergeThumbTouchStart"
              bindtouchmove="handlePdfMergeThumbTouchMove"
              bindtouchend="handlePdfMergeThumbTouchEnd"
            >
              <view class="pdf-thumb-icon">📄</view>
              <text class="pdf-thumb-name">{{index + 1}}</text>
              <view class="pdf-thumb-delete" data-index="{{index}}" catchtap="handleDeleteThumbImage">
                <text class="pdf-thumb-delete-icon">✕</text>
              </view>
            </view>
          </view>
        </scroll-view>

        <!-- 悬浮拖拽元素 -->
        <view 
          wx:if="{{pdfMergeDraggingIndex !== null}}" 
          class="pdf-merge-floating-drag"
          style="left: {{pdfMergeFloatingLeft}}px; top: {{pdfMergeFloatingTop}}px;"
        >
          <view class="pdf-merge-floating-content">
            <text class="pdf-merge-floating-icon">📄</text>
          </view>
        </view>
      </view>

      <!-- PDF合并结果展示 -->
      <view class="image-preview" wx:if="{{pdfMergeResultReady}}">
        <view class="file-preview">
          <text class="file-preview__icon">📄</text>
          <text class="file-preview__name">{{pdfMergeResultName}}</text>
        </view>
        <text class="result-card__title" style="margin-top: 16rpx; text-align: center;">{{pdfMergeResultHeadline}}</text>
        <view class="chips-wrap" wx:if="{{pdfMergeResultMetaLines.length}}" style="justify-content: center; margin-top: 12rpx;">
          <text class="chip-static" wx:for="{{pdfMergeResultMetaLines}}" wx:key="*this">{{item}}</text>
        </view>
        <view class="action-card__buttons" style="margin-top: 24rpx;">
          <view class="btn-primary action-card__button" bindtap="previewPdfMergeResult">预览文件</view>
          <view class="btn-primary action-card__button" bindtap="downloadPdfMergeResult">下载文件</view>
          <view class="btn-ghost action-card__button" wx:if="{{pdfMergeResultRemoteUrl}}" bindtap="copyPdfMergeUrl">复制链接</view>
        </view>
      </view>

      <!-- 普通文件列表（其他工具用） -->
      <view class="file-list" wx:if="{{tool.id !== 'pdf-merge' && backendFiles.length && !pdfToWordResultReady && !audioConvertResultReady && !pdfSplitResultReady && !officeToPdfResultReady}}">
        <view class="file-item" wx:for="{{backendFiles}}" wx:key="path">
          <text class="file-item__name">{{item.name}}</text>
          <text class="file-item__meta">{{item.sizeText}}</text>
        </view>
      </view>

      <!-- PDF拆分结果展示 -->
      <view class="image-preview" wx:if="{{pdfSplitResultReady}}">
        <view class="file-preview">
          <text class="file-preview__icon">📄</text>
          <text class="file-preview__name">{{pdfSplitResultName}}</text>
        </view>
        <text class="result-card__title" style="margin-top: 16rpx; text-align: center;">{{pdfSplitResultHeadline}}</text>
        <view class="chips-wrap" wx:if="{{pdfSplitResultDetail}}" style="justify-content: center; margin-top: 8rpx;">
          <text class="chip-static">{{pdfSplitResultDetail}}</text>
        </view>
        <view class="chips-wrap" wx:if="{{pdfSplitResultMetaLines.length}}" style="justify-content: center; margin-top: 12rpx;">
          <text class="chip-static" wx:for="{{pdfSplitResultMetaLines}}" wx:key="*this">{{item}}</text>
        </view>
        
        <!-- 附件列表（拆分出来的多个PDF） -->
        <view class="pdf-split-attachments" wx:if="{{pdfSplitAttachments.length}}">
          <view class="section-head">
            <text class="eyebrow">附件</text>
            <text class="section-title">拆分结果</text>
          </view>
          <view class="attachment-list">
            <view class="attachment-item" wx:for="{{pdfSplitAttachments}}" wx:key="url" bindtap="previewPdfSplitAttachment" data-url="{{item.url}}" data-name="{{item.name}}">
              <text class="attachment-icon">📄</text>
              <view class="attachment-info">
                <text class="attachment-name">{{item.name}}</text>
                <text class="attachment-meta" wx:if="{{item.label}}">{{item.label}}</text>
                <text class="attachment-meta" wx:else>{{item.sizeBytes ? formatFileSize(item.sizeBytes) : ''}}</text>
              </view>
              <text class="attachment-action">预览</text>
            </view>
          </view>
        </view>

        <view class="action-card__buttons" style="margin-top: 24rpx;">
          <view class="btn-primary action-card__button" bindtap="previewPdfSplitResult" wx:if="{{pdfSplitResultPath || pdfSplitResultRemoteUrl}}">预览文件</view>
          <view class="btn-primary action-card__button" bindtap="downloadPdfSplitResult" wx:if="{{pdfSplitResultPath || pdfSplitResultRemoteUrl}}">下载文件</view>
          <view class="btn-ghost action-card__button" wx:if="{{pdfSplitResultRemoteUrl}}" bindtap="copyPdfSplitUrl">复制链接</view>
        </view>
      </view>

      <view class="image-preview" wx:if="{{pdfToWordResultReady}}">
        <view class="file-preview">
          <text class="file-preview__icon">📄</text>
          <text class="file-preview__name">{{pdfToWordResultName}}</text>
        </view>
        <text class="result-card__title" style="margin-top: 16rpx; text-align: center;">{{pdfToWordResultHeadline}}</text>
        <view class="chips-wrap" wx:if="{{pdfToWordResultMetaLines.length}}" style="justify-content: center; margin-top: 12rpx;">
          <text class="chip-static" wx:for="{{pdfToWordResultMetaLines}}" wx:key="*this">{{item}}</text>
        </view>
        <view class="action-card__buttons" style="margin-top: 24rpx;">
          <view class="btn-primary action-card__button" bindtap="previewPdfToWordResult">预览文件</view>
          <view class="btn-primary action-card__button" bindtap="downloadPdfToWordResult">下载文件</view>
          <view class="btn-ghost action-card__button" wx:if="{{pdfToWordResultRemoteUrl}}" bindtap="copyPdfToWordUrl">复制链接</view>
        </view>
      </view>

      <view class="image-preview" wx:if="{{officeToPdfResultReady}}">
        <view class="file-preview">
          <text class="file-preview__icon">📄</text>
          <text class="file-preview__name">{{officeToPdfResultName}}</text>
        </view>
        <text class="result-card__title" style="margin-top: 16rpx; text-align: center;">{{officeToPdfResultHeadline}}</text>
        <view class="chips-wrap" wx:if="{{officeToPdfResultDetail}}" style="justify-content: center; margin-top: 8rpx;">
          <text class="chip-static">{{officeToPdfResultDetail}}</text>
        </view>
        <view class="chips-wrap" wx:if="{{officeToPdfResultMetaLines.length}}" style="justify-content: center; margin-top: 12rpx;">
          <text class="chip-static" wx:for="{{officeToPdfResultMetaLines}}" wx:key="*this">{{item}}</text>
        </view>
        <view class="action-card__buttons" style="margin-top: 24rpx;">
          <view class="btn-primary action-card__button" bindtap="previewOfficeToPdfResult" wx:if="{{officeToPdfResultPath || officeToPdfResultRemoteUrl}}">预览文件</view>
          <view class="btn-primary action-card__button" bindtap="downloadOfficeToPdfResult" wx:if="{{officeToPdfResultPath || officeToPdfResultRemoteUrl}}">下载文件</view>
          <view class="btn-ghost action-card__button" wx:if="{{officeToPdfResultRemoteUrl}}" bindtap="copyOfficeToPdfUrl">复制链接</view>
        </view>
      </view>

      <view class="image-preview" wx:if="{{audioConvertResultReady}}">
        <video
          wx:if="{{audioConvertResultKind === 'video'}}"
          id="videoPlayer"
          class="media-preview__video"
          src="{{audioConvertResultPath || audioConvertResultRemoteUrl}}"
          controls
          show-center-play-btn
          show-fullscreen-btn
          show-play-btn
          autoplay="{{false}}"
          object-fit="contain"
          poster="{{audioConvertResultPath ? '' : ''}}"
          initial-time="0"
          show-snapshot-btn
          show-screen-lock-button
          enable-progress-gesture
          vslide-gesture-in-fullscreen
        ></video>
        <view wx:else class="file-preview">
          <text class="file-preview__icon">🎵</text>
          <text class="file-preview__name">{{audioConvertResultName}}</text>
        </view>
        <text class="result-card__title" style="margin-top: 16rpx; text-align: center;">{{audioConvertResultHeadline}}</text>
        <view class="chips-wrap" wx:if="{{audioConvertResultMetaLines.length}}" style="justify-content: center; margin-top: 12rpx;">
          <text class="chip-static" wx:for="{{audioConvertResultMetaLines}}" wx:key="*this">{{item}}</text>
        </view>
        <view class="action-card__buttons" style="margin-top: 24rpx;">
          <view class="btn-primary action-card__button" bindtap="previewAudioConvertResult">{{audioConvertResultKind === 'audio' && audioConvertIsPlaying ? '暂停预览' : (audioConvertResultKind === 'video' ? '打开预览' : '预览')}}</view>
          <view class="btn-ghost action-card__button" bindtap="saveAudioConvertResult">保存</view>
          <view class="btn-ghost action-card__button" wx:if="{{audioConvertResultRemoteUrl}}" bindtap="copyAudioConvertResultLink">复制链接</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{showBackendRangeInput}}">
    <view class="section-head">
      <view>
        <text class="eyebrow">Range</text>
        <text class="section-title">输入页码范围</text>
      </view>
    </view>

    <view class="card form-card">
      <input class="field-input" value="{{pageRange}}" bindinput="handlePageRangeInput" placeholder="例如 1-3,5,8-10" />
    </view>
  </view>

  <view class="section" wx:if="{{showCustomSize}}">
    <view class="section-head">
      <view>
        <text class="eyebrow">Custom</text>
        <text class="section-title">输入自定义尺寸</text>
      </view>
    </view>

    <view class="card form-card">
      <view style="margin-bottom: 24rpx;">
        <view style="font-size: 28rpx; color: #333; margin-bottom: 12rpx;">宽度 (像素)</view>
        <input class="field-input" type="number" value="{{customWidth}}" bindinput="handleCustomWidth" placeholder="例如 1080" />
      </view>
      <view>
        <view style="font-size: 28rpx; color: #333; margin-bottom: 12rpx;">高度 (像素)</view>
        <input class="field-input" type="number" value="{{customHeight}}" bindinput="handleCustomHeight" placeholder="例如 1920" />
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{showTextInput}}">
    <view class="section-head">
      <view>
        <text class="eyebrow">Content</text>
        <text class="section-title">输入二维码内容</text>
      </view>
    </view>

    <view class="card">
      <textarea class="text-area" maxlength="-1" value="{{textInput}}" bindinput="handleTextInput" placeholder="输入链接、文本、联系方式等内容" />
      <view class="qr-logo-row">
        <view class="btn-ghost qr-logo-button" bindtap="chooseQrLogo">{{qrLogoInput ? '更换 Logo' : '上传 Logo'}}</view>
        <view class="btn-ghost qr-logo-button" wx:if="{{qrLogoInput}}" bindtap="removeQrLogo">移除</view>
      </view>
      <view class="qr-logo-preview" wx:if="{{qrLogoInput}}">
        <image class="qr-logo-preview__image" src="{{qrLogoInput.path}}" mode="aspectFill"></image>
        <text class="qr-logo-preview__meta">{{qrLogoInput.width}} × {{qrLogoInput.height}} · {{qrLogoInput.sizeText}}</text>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{showUnitConverter}}">
    <view class="section-head">
      <view>
        <text class="eyebrow">Convert</text>
        <text class="section-title">输入换算数值</text>
      </view>
    </view>

    <view class="card form-card">
      <input class="field-input" type="digit" value="{{numberInput}}" bindinput="handleNumberInput" placeholder="输入数值" />
      <picker range="{{unitOptions}}" bindchange="handleUnitChange" data-field="fromUnit">
        <view class="picker-line">从：{{fromUnit}}</view>
      </picker>
      <picker range="{{unitOptions}}" bindchange="handleUnitChange" data-field="toUnit">
        <view class="picker-line">到：{{toUnit}}</view>
      </picker>
      <view class="btn-ghost picker-button" bindtap="swapUnits">交换单位</view>
      
      <view class="unit-result" wx:if="{{unitConvertResult}}">
        <text class="unit-result-value">{{unitConvertResult}}</text>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{tool.id !== 'photo-id' && tool.id !== 'unit-convert'}}">
    <view class="card action-card">
      <text class="action-card__title">{{actionTitle}}</text>
      
      <!-- 支付方式选择（积分足够时可选）-->
      <view class="payment-options" wx:if="{{billing && billing.mode === 'points'}}">
        <view 
          class="payment-option {{selectedPayment === 'points' ? 'selected' : ''}}"
          bindtap="selectPayment"
          data-type="points"
        >
          <view class="payment-option-icon">🎟️</view>
          <view class="payment-option-content">
            <text class="payment-option-title">使用积分</text>
            <text class="payment-option-desc">消耗 {{tool.points}} 积分（当前 {{userState.points}} 积分）</text>
          </view>
          <view class="payment-option-check">
            <view class="checkmark {{selectedPayment === 'points' ? 'checked' : ''}}"></view>
          </view>
        </view>
        
        <view 
          class="payment-option {{selectedPayment === 'direct' ? 'selected' : ''}}"
          bindtap="selectPayment"
          data-type="direct"
        >
          <view class="payment-option-icon">💳</view>
          <view class="payment-option-content">
            <text class="payment-option-title">直接支付</text>
            <text class="payment-option-desc">支付 ¥{{directPriceDisplay}}（{{tool.points}}积分等值）</text>
          </view>
          <view class="payment-option-check">
            <view class="checkmark {{selectedPayment === 'direct' ? 'checked' : ''}}"></view>
          </view>
        </view>
      </view>

      <!-- 积分不足提示 -->
      <view class="payment-locked-tip" wx:if="{{billing && billing.mode === 'locked'}}">
        <text class="payment-locked-text">积分不足，需支付 ¥{{directPriceDisplay}} 后使用</text>
      </view>
      
      <text class="action-card__copy">{{billing ? billing.text : ''}}</text>
      <text class="action-card__hint" wx:if="{{actionHint}}">{{actionHint}}</text>

      <view class="action-card__buttons">
        <view class="btn-primary action-card__button {{primaryActionDisabled || isWorking ? 'action-card__button-disabled' : ''}}" bindtap="handleExecute">
          <view wx:if="{{isWorking}}" class="loading-wrap">
            <view class="loading-spinner">
              <view class="loading-dot"></view>
              <view class="loading-dot"></view>
              <view class="loading-dot"></view>
            </view>
            <text class="loading-text">处理中</text>
          </view>
          <text wx:else>{{primaryActionText}}</text>
        </view>
        <view class="btn-ghost action-card__button" bindtap="handleFavorite">{{favorite ? '取消收藏' : '收藏工具'}}</view>
      </view>
    </view>
  </view>
  
  <!-- 单位换算只显示收藏按钮 -->
  <view class="section" wx:if="{{tool.id === 'unit-convert'}}">
    <view class="card action-card">
      <view class="action-card__buttons">
        <view class="btn-ghost action-card__button" bindtap="handleFavorite">{{favorite ? '取消收藏' : '收藏工具'}}</view>
      </view>
    </view>
  </view>







  <view class="section" wx:if="{{showRecentTasks && relatedTasks.length}}">
    <view class="section-head">
      <view>
        <text class="eyebrow">Recent</text>
        <text class="section-title">最近处理记录</text>
      </view>
    </view>

    <view class="related-list">
      <view class="card related-card" wx:for="{{relatedTasks}}" wx:key="id" data-id="{{item.id}}" bindtap="openTask">
        <view class="row space-between">
          <text class="related-card__title">{{item.statusText}}</text>
          <text class="related-card__time">{{item.createdLabel}}</text>
        </view>
        <text class="related-card__copy">{{item.finalDetail || item.resultHeadline}}</text>
      </view>
    </view>
  </view>

  <canvas
    canvas-id="toolCanvas"
    class="tool-canvas"
    style="width: {{canvasWidth}}px; height: {{canvasHeight}}px;"
  ></canvas>

  <view wx:if="{{showProcessingOverlay}}" class="processing-overlay">
    <view class="processing-panel">
      <view class="processing-stage">
        <view class="processing-orbit">
          <view class="processing-orbit__ring"></view>
          <view class="processing-orbit__ring processing-orbit__ring--second"></view>
          <view class="processing-orbit__core">
            <view class="processing-core__bar processing-core__bar--one"></view>
            <view class="processing-core__bar processing-core__bar--two"></view>
            <view class="processing-core__bar processing-core__bar--three"></view>
          </view>
          <view class="processing-chip processing-chip--one"></view>
          <view class="processing-chip processing-chip--two"></view>
          <view class="processing-chip processing-chip--three"></view>
        </view>
      </view>
      <text class="processing-title">{{processingTitle || '处理中'}}</text>
      <text class="processing-status">{{processingStatus}}</text>
      <view class="processing-progress-wrap">
        <view class="processing-progress-track">
          <view class="processing-progress-fill" style="width: {{processingDisplayProgress}}%;"></view>
          <view class="processing-progress-spark" style="left: {{processingDisplayProgress}}%;"></view>
        </view>
        <view class="processing-progress-row">
          <text class="processing-progress-label">进度</text>
          <text class="processing-progress-text">{{processingDisplayProgressText}}%</text>
        </view>
      </view>
      <view class="processing-actions">
        <view class="processing-btn-background" bindtap="minimizeToBackground">
          <text class="processing-btn-background__icon">⬇</text>
          <text class="processing-btn-background__text">后台运行</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{showBackgroundTaskFloat}}" class="bg-task-float" bindtap="restoreFromBackground">
    <view class="bg-task-float__badge">
      <text class="bg-task-float__percent">{{backgroundTaskProgress}}%</text>
    </view>
    <view class="bg-task-float__info">
      <text class="bg-task-float__title">{{backgroundTaskTitle}}</text>
      <view class="bg-task-float__bar-wrap">
        <view class="bg-task-float__bar" style="width: {{backgroundTaskProgress}}%;"></view>
      </view>
    </view>
  </view>
</view>
