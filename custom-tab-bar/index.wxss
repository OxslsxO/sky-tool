/* ===== 温馨暖色调 TabBar 样式 ===== */

.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
  padding-bottom: env(safe-area-inset-bottom);
  background: linear-gradient(180deg, rgba(255, 252, 247, 0.95) 0%, rgba(250, 245, 238, 0.98) 100%);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(230, 210, 190, 0.4);
  box-shadow: 0 -4rpx 24rpx rgba(180, 140, 100, 0.08);
}

/* 顶部柔和光晕 */
.tab-bar-glow {
  position: absolute;
  top: -20rpx;
  left: 10%;
  right: 10%;
  height: 40rpx;
  background: radial-gradient(ellipse at center, rgba(255, 200, 150, 0.15) 0%, transparent 70%);
  pointer-events: none;
}

.tab-bar-inner {
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: 100rpx;
  padding: 0 20rpx;
}

/* ===== Tab 项 ===== */
.tab-bar-item {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 24rpx;
  transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* 点击反馈 */
.tab-bar-item:active {
  transform: scale(0.92);
  background: rgba(230, 200, 170, 0.15);
}

/* ===== 图标容器 ===== */
.tab-icon-wrapper {
  position: relative;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4rpx;
}

/* 默认图标 */
.tab-icon {
  position: absolute;
  font-size: 40rpx;
  opacity: 0.55;
  filter: grayscale(30%);
  transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  transform: scale(1);
}

/* 选中图标 */
.tab-icon-active {
  position: absolute;
  font-size: 40rpx;
  opacity: 0;
  transform: scale(0.5) translateY(10rpx);
  transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  filter: drop-shadow(0 2rpx 4rpx rgba(200, 120, 60, 0.3));
}

/* ===== 文字 ===== */
.tab-text {
  font-size: 20rpx;
  color: #b8a898;
  font-weight: 400;
  letter-spacing: 1rpx;
  transition: all 0.3s ease;
}

/* ===== 选中状态 ===== */
.tab-bar-item.active {
  background: linear-gradient(135deg, rgba(255, 230, 200, 0.4) 0%, rgba(255, 210, 170, 0.3) 100%);
  box-shadow: inset 0 1rpx 2rpx rgba(255, 255, 255, 0.6), 0 2rpx 8rpx rgba(200, 140, 80, 0.1);
}

.tab-bar-item.active .tab-icon {
  opacity: 0;
  transform: scale(0.5) translateY(-10rpx);
}

.tab-bar-item.active .tab-icon-active {
  opacity: 1;
  transform: scale(1.15) translateY(0);
}

.tab-bar-item.active .tab-text {
  color: #c4783a;
  font-weight: 600;
  text-shadow: 0 1rpx 2rpx rgba(200, 120, 60, 0.1);
}

/* ===== 选中指示器（小圆点） ===== */
.tab-bar-item.active::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 16rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #e8a87c, #d4956a);
  border-radius: 2rpx;
  box-shadow: 0 1rpx 4rpx rgba(200, 120, 60, 0.2);
}

/* ===== 首页特殊样式（中间凸起） ===== */
.tab-bar-item:nth-child(1).active {
  background: linear-gradient(135deg, rgba(255, 220, 180, 0.5) 0%, rgba(255, 200, 150, 0.4) 100%);
}

/* ===== 会员特殊样式（金色质感） ===== */
.tab-bar-item:nth-child(3).active {
  background: linear-gradient(135deg, rgba(255, 235, 200, 0.5) 0%, rgba(255, 220, 160, 0.4) 100%);
}

.tab-bar-item:nth-child(3).active .tab-text {
  color: #c4953a;
}

.tab-bar-item:nth-child(3).active::after {
  background: linear-gradient(90deg, #e8c07c, #d4a56a);
}
