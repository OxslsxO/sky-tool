.tool-card {
  min-height: 254rpx;
  border-radius: 30rpx;
  padding: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 14rpx 34rpx rgba(35, 46, 40, 0.07);
}

.tool-card--compact {
  min-height: 214rpx;
}

.tool-card__top,
.tool-card__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.tool-card__badge-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.tool-card__badge,
.tool-card__member {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1.2;
}

.tool-card__badge {
  background: rgba(29, 92, 75, 0.12);
  color: #1d5c4b;
}

.tool-card__member {
  background: rgba(214, 106, 77, 0.12);
  color: #c66543;
}

.tool-card__points {
  font-size: 22rpx;
  color: #6e6a61;
}

.tool-card__name {
  display: block;
  margin-top: 26rpx;
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #1d2624;
}

.tool-card__tagline {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #626761;
}

.tool-card__footer {
  margin-top: 26rpx;
}

.tool-card__format {
  font-size: 22rpx;
  color: #7c786f;
}

.tool-card__link {
  font-size: 24rpx;
  color: #1d5c4b;
}
