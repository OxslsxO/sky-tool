/* 任务详情 Hero 区域 - 浅色背景适配深色文字 */
.task-hero--processing .eyebrow,
.task-hero--success .eyebrow,
.task-hero--failed .eyebrow,
.task-hero--expired .eyebrow {
  color: rgba(45, 52, 54, 0.6);
}

.task-hero--processing .hero-title,
.task-hero--success .hero-title,
.task-hero--failed .hero-title,
.task-hero--expired .hero-title {
  color: #2D3436;
  text-shadow: none;
}

.task-hero--processing .hero-copy,
.task-hero--success .hero-copy,
.task-hero--failed .hero-copy,
.task-hero--expired .hero-copy {
  color: rgba(45, 52, 54, 0.75);
}

.task-hero--processing {
  background: linear-gradient(145deg, #dbe9e2 0%, #f1f8f4 62%, #ffffff 100%);
}

.task-hero--success {
  background: linear-gradient(145deg, #e6efe7 0%, #f7fbf8 62%, #ffffff 100%);
}

.task-hero--failed {
  background: linear-gradient(145deg, #f3e0d9 0%, #fbf3f0 62%, #ffffff 100%);
}

.task-hero--expired {
  background: linear-gradient(145deg, #e9e9e9 0%, #f5f5f5 62%, #ffffff 100%);
}

.detail-card {
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.94), rgba(244, 240, 233, 0.96));
}

.detail-card__title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2b28;
}

.detail-card__copy {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #666b64;
}

.detail-card__text-result {
  margin-top: 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 249, 246, 0.95);
  overflow: hidden;
}

.detail-card__text-scroll {
  max-height: 600rpx;
  padding: 24rpx;
}

.detail-card__text-content {
  font-size: 26rpx;
  line-height: 1.8;
  color: #2d3436;
  word-break: break-all;
}

.detail-card__text-actions {
  display: flex;
  justify-content: center;
  padding: 16rpx 24rpx 20rpx;
  border-top: 1rpx solid rgba(200, 149, 108, 0.1);
}

.detail-card__copy-btn {
  font-size: 24rpx;
  padding: 10rpx 32rpx;
}

.detail-card__preview {
  width: 100%;
  height: 420rpx;
  margin-top: 20rpx;
  border-radius: 24rpx;
  background: rgba(244, 240, 233, 0.9);
}

.detail-card__meta {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 18rpx;
}

.detail-card__meta-line {
  font-size: 22rpx;
  color: #6d7268;
}

.detail-card__attachments {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 20rpx;
}

.detail-card__document {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  margin-top: 20rpx;
  border-radius: 24rpx;
  background: rgba(244, 240, 233, 0.9);
}

.detail-card__document-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #1d5c4b 0%, #2d7a63 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.detail-card__document-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.detail-card__document-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2b28;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-card__document-hint {
  font-size: 22rpx;
  color: #6d7268;
}

.detail-card__attachment {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(244, 240, 233, 0.9);
}

.detail-card__attachment-name {
  flex: 1;
  font-size: 24rpx;
  color: #1f2b28;
}

.detail-card__attachment-link {
  font-size: 22rpx;
  color: #1d5c4b;
}

.action-card__buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 18rpx;
}

.action-card__button {
  flex: 1;
  min-width: 200rpx;
}

.task-detail__main-button {
  margin-top: 18rpx;
}

.audio-player {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  margin-top: 20rpx;
  border-radius: 24rpx;
  background: rgba(244, 240, 233, 0.9);
}

.audio-cover {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #1d5c4b 0%, #2d7a63 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.audio-play-icon {
  font-size: 48rpx;
  color: #fff;
}

.audio-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.audio-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2b28;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.audio-meta {
  font-size: 22rpx;
  color: #6d7268;
}
