.bg-float {
  position: fixed;
  top: 24rpx;
  right: 24rpx;
  z-index: 999;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.bg-float__list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.bg-float__item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx 24rpx 14rpx 14rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  box-shadow:
    0 12rpx 40rpx rgba(200, 149, 108, 0.18),
    0 4rpx 12rpx rgba(200, 149, 108, 0.08);
  border: 2rpx solid rgba(200, 149, 108, 0.1);
}

.bg-float__badge {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #C8956C, #D4A574);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.bg-float__percent {
  font-size: 20rpx;
  font-weight: 800;
  color: #FFFFFF;
}

.bg-float__info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 140rpx;
}

.bg-float__title {
  font-size: 22rpx;
  font-weight: 700;
  color: #2D3436;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bg-float__bar-wrap {
  width: 100%;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(200, 149, 108, 0.1);
  overflow: hidden;
}

.bg-float__bar {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #C8956C, #7DB9A8);
  transition: width 0.3s ease;
}
