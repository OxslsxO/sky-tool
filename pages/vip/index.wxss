.vip-hero {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.vip-hero__status {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.vip-hero__badge {
  display: inline-block;
  width: fit-content;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1d5c4b, #3a8d76);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
}

.vip-hero__badge--inactive {
  background: rgba(0, 0, 0, 0.08);
  color: #7a776d;
}

.vip-hero__plan {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2b28;
}

.vip-hero__expire {
  font-size: 22rpx;
  color: #7a776d;
}

.vip-hero__points {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.vip-hero__points-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #1d5c4b;
  line-height: 1.2;
}

.vip-hero__points-label {
  font-size: 22rpx;
  color: #7a776d;
}

.debug-add-btn {
  margin-top: 8rpx;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #1d5c4b, #3a8d76);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  border-radius: 999rpx;
  text-align: center;
}

.tab-bar {
  display: flex;
  gap: 0;
  background: rgba(244, 240, 233, 0.6);
  border-radius: 20rpx;
  padding: 6rpx;
  margin-bottom: 24rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #7a776d;
  transition: all 0.2s ease;
}

.tab-active {
  background: #ffffff;
  color: #1d5c4b;
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.plan-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.plan-card {
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.94), rgba(244, 240, 233, 0.96));
  transition: all 0.2s ease;
}

.plan-card--recommended {
  background: linear-gradient(145deg, #e3efe9 0%, #f4faf6 64%, #ffffff 100%);
}

.plan-card--selected {
  border: 2rpx solid #1d5c4b;
  box-shadow: 0 0 0 4rpx rgba(29, 92, 75, 0.1);
}

.plan-card__name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2d29;
}

.plan-card__badge {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(29, 92, 75, 0.1);
  color: #1d5c4b;
  font-size: 22rpx;
}

.plan-card__price-row {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  margin-top: 18rpx;
}

.plan-card__price {
  font-size: 48rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #1d5c4b;
}

.plan-card__period {
  font-size: 24rpx;
  color: #7a776d;
}

.plan-card__copy {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #666b64;
}

.records-empty {
  display: block;
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: #7a776d;
}

.records-list {
  display: flex;
  flex-direction: column;
}

.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.record-item:last-child {
  border-bottom: none;
}

.record-item__left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.record-item__title {
  font-size: 26rpx;
  color: #1f2b28;
  font-weight: 500;
}

.record-item__time {
  font-size: 22rpx;
  color: #7a776d;
}

.record-item__change {
  font-size: 30rpx;
  font-weight: 700;
}

.record-plus {
  color: #1d5c4b;
}

.record-minus {
  color: #d66a4d;
}

.record-zero {
  color: #7a776d;
}
