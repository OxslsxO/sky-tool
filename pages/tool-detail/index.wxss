.direct-hero {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
  min-height: 140rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(145deg, #e9e2d6 0%, #f8f5ef 58%, #ffffff 100%);
}

.hero-left {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex: 1;
}

.hero-right {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  align-items: flex-end;
}

.user-info {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.user-info__label {
  font-size: 22rpx;
  line-height: 1.3;
  color: #8b6f5c;
  font-weight: 600;
}

.user-info__value {
  font-size: 24rpx;
  line-height: 1.3;
  color: #5a4a3a;
}

.direct-hero .hero-title {
  position: relative;
  z-index: 2;
  margin-top: 0;
}

.hero-cost {
  position: relative;
  z-index: 2;
  display: block;
  width: fit-content;
  padding: 12rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.66);
  border: 1rpx solid rgba(255, 255, 255, 0.78);
  font-size: 26rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #9d5c49;
}

.cost-hint {
  margin-top: 16rpx;
  padding: 12rpx 16rpx;
  background: rgba(157, 92, 73, 0.08);
  border-radius: 12rpx;
  text-align: center;
}

.cost-hint__text {
  font-size: 24rpx;
  line-height: 1.4;
  color: #8b6f5c;
}

.tag-row {
  position: relative;
  z-index: 2;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-row--spaced {
  margin-top: 18rpx;
}

.upload-card {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.upload-card__copy {
  display: block;
  font-size: 24rpx;
  line-height: 1.7;
  color: #666b64;
}

.option-block {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-block__title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2b28;
}

.picker-button {
  margin-bottom: 20rpx;
}

.image-preview {
  display: flex;
  flex-direction: column;
}

.image-preview__image {
  width: 100%;
  height: 420rpx;
  border-radius: 24rpx;
  background: rgba(244, 240, 233, 0.9);
}

.image-preview__meta {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #6a6f66;
}

.ocr-result {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.ocr-result__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.ocr-result__meta {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: #6a6f66;
}

.ocr-result__copy-all {
  flex-shrink: 0;
  min-width: 150rpx;
  margin-bottom: 0;
  text-align: center;
}

.ocr-result__scroll {
  width: 100%;
  max-height: 720rpx;
  min-height: 280rpx;
  border-radius: 20rpx;
  background: rgba(244, 240, 233, 0.9);
  box-sizing: border-box;
  overflow: hidden;
}

.ocr-line {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 18rpx 18rpx;
  border-bottom: 1rpx solid rgba(31, 43, 40, 0.08);
}

.ocr-empty {
  padding: 56rpx 24rpx;
  text-align: center;
  font-size: 26rpx;
  line-height: 1.5;
  color: #6a6f66;
}

.ocr-line__text {
  flex: 1;
  font-size: 27rpx;
  line-height: 1.72;
  color: #1f2b28;
  word-break: break-word;
  user-select: text;
}

.ocr-line__copy {
  flex-shrink: 0;
  min-width: 82rpx;
  padding: 10rpx 14rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid rgba(29, 92, 75, 0.18);
  font-size: 22rpx;
  line-height: 1.3;
  color: #1d5c4b;
  text-align: center;
}

.file-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.file-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(244, 240, 233, 0.9);
}

.file-item__name {
  flex: 1;
  font-size: 24rpx;
  color: #1f2b28;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-width: 0;
}

.file-item__meta {
  font-size: 22rpx;
  color: #6a6f66;
}

.form-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.field-input,
.picker-line {
  min-height: 84rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: rgba(244, 240, 233, 0.88);
  font-size: 26rpx;
  line-height: 84rpx;
  color: #1d2421;
  box-sizing: border-box;
}

.text-area {
  width: 100%;
  min-height: 260rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(244, 240, 233, 0.88);
  font-size: 26rpx;
  line-height: 1.7;
  color: #1d2421;
  box-sizing: border-box;
}

.qr-logo-row {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.qr-logo-button {
  flex: 1;
  margin-bottom: 0;
}

.qr-logo-preview {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
}

.qr-logo-preview__image {
  width: 88rpx;
  height: 88rpx;
  border-radius: 16rpx;
  background: rgba(244, 240, 233, 0.9);
}

.qr-logo-preview__meta {
  flex: 1;
  font-size: 22rpx;
  color: #6a6f66;
}

.backend-card {
  background: linear-gradient(145deg, #f1e1da 0%, #fbf3ef 64%, #ffffff 100%);
}

.backend-card__title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2b28;
}

.backend-card__copy {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #666b64;
}

.action-card__title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2b28;
}

.action-card__copy {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #666b64;
}

.action-card__hint {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #9d5c49;
}

.action-card__buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.payment-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}

.payment-option {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 2rpx solid #e8ddd3;
  transition: all 0.2s ease;
}

.payment-option.selected {
  border-color: #c4783a;
  background: rgba(196, 120, 58, 0.08);
}

.payment-option-disabled {
  opacity: 0.45;
}

.payment-option-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.payment-option-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.payment-option-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #3e2723;
}

.payment-option-desc {
  font-size: 24rpx;
  color: #8d6e63;
}

.payment-option-check {
  margin-left: 16rpx;
}

.checkmark {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid #d7ccc8;
  transition: all 0.2s ease;
}

.checkmark.checked {
  background: #c4783a;
  border-color: #c4783a;
}

.payment-locked-tip {
  margin-top: 16rpx;
  padding: 16rpx 24rpx;
  background: rgba(255, 152, 0, 0.08);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 152, 0, 0.2);
}

.payment-locked-text {
  font-size: 26rpx;
  color: #e65100;
}

.action-card__button {
  flex: 1;
  min-width: 240rpx;
}

.action-card__button-disabled {
  opacity: 0.55;
}

.result-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.result-card__image {
  width: 100%;
  border-radius: 24rpx;
  background: rgba(244, 240, 233, 0.9);
  overflow: hidden;
}

.result-card__title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2b28;
}

.result-card__name {
  display: block;
  font-size: 24rpx;
  color: #6a6f66;
}

.related-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.related-card__title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2b28;
}

.related-card__time {
  font-size: 22rpx;
  color: #7a776d;
}

.related-card__copy {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #666b64;
}

.tool-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  opacity: 0;
  pointer-events: none;
}

.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.loading-spinner {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.loading-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #ffffff;
  animation: loading-bounce 1.4s ease-in-out infinite both;
}

.loading-dot:nth-child(1) {
  animation-delay: -0.32s;
}

.loading-dot:nth-child(2) {
  animation-delay: -0.16s;
}

.loading-dot:nth-child(3) {
  animation-delay: 0s;
}

@keyframes loading-bounce {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.5;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

.loading-text {
  font-size: 28rpx;
  color: #ffffff;
}

.chip-color {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.chip-color__dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 8rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.1);
  flex-shrink: 0;
}

.processing-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(16, 22, 20, 0.72);
  backdrop-filter: blur(10rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.processing-panel {
  width: 580rpx;
  min-height: 520rpx;
  padding: 48rpx 40rpx 42rpx;
  border-radius: 28rpx;
  background: #fffaf3;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 22rpx;
  box-shadow: 0 28rpx 90rpx rgba(0, 0, 0, 0.32);
  overflow: hidden;
}

.processing-stage {
  position: relative;
  width: 220rpx;
  height: 190rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.processing-orbit {
  position: relative;
  width: 174rpx;
  height: 174rpx;
}

.processing-orbit__ring {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  width: 150rpx;
  height: 150rpx;
  border: 4rpx solid rgba(29, 92, 75, 0.18);
  border-top-color: #1d5c4b;
  border-right-color: #d66a4d;
  border-radius: 50%;
  animation: processing-spin 2.4s linear infinite;
}

.processing-orbit__ring--second {
  top: 34rpx;
  left: 34rpx;
  width: 106rpx;
  height: 106rpx;
  border-color: rgba(214, 106, 77, 0.18);
  border-bottom-color: #d66a4d;
  border-left-color: #1d5c4b;
  animation-direction: reverse;
  animation-duration: 1.8s;
}

.processing-orbit__core {
  position: absolute;
  top: 53rpx;
  left: 47rpx;
  width: 80rpx;
  height: 68rpx;
  padding: 12rpx;
  border-radius: 20rpx;
  background: #1f2b28;
  box-shadow: 0 14rpx 28rpx rgba(31, 43, 40, 0.24);
  box-sizing: border-box;
}

.processing-core__bar {
  height: 8rpx;
  border-radius: 999rpx;
  background: #f6d26b;
  animation: processing-bars 1.2s ease-in-out infinite;
}

.processing-core__bar + .processing-core__bar {
  margin-top: 8rpx;
}

.processing-core__bar--one {
  width: 100%;
}

.processing-core__bar--two {
  width: 70%;
  animation-delay: 0.14s;
}

.processing-core__bar--three {
  width: 46%;
  animation-delay: 0.28s;
}

.processing-chip {
  position: absolute;
  width: 22rpx;
  height: 22rpx;
  border-radius: 7rpx;
  background: #d66a4d;
  box-shadow: 0 8rpx 18rpx rgba(214, 106, 77, 0.28);
  animation: processing-float 1.9s ease-in-out infinite;
}

.processing-chip--one {
  top: 20rpx;
  left: 18rpx;
}

.processing-chip--two {
  right: 10rpx;
  top: 70rpx;
  width: 18rpx;
  height: 18rpx;
  background: #1d5c4b;
  animation-delay: 0.24s;
}

.processing-chip--three {
  left: 52rpx;
  bottom: 8rpx;
  width: 16rpx;
  height: 16rpx;
  background: #f6d26b;
  animation-delay: 0.48s;
}

@keyframes processing-spin {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

@keyframes processing-bars {
  0%, 100% {
    opacity: 0.55;
    transform: scaleX(0.7);
    transform-origin: left center;
  }
  50% {
    opacity: 1;
    transform: scaleX(1);
    transform-origin: left center;
  }
}

@keyframes processing-float {
  0%, 100% {
    transform: translate3d(0, 0, 0) rotate(0deg);
  }
  50% {
    transform: translate3d(0, -16rpx, 0) rotate(10deg);
  }
}

.processing-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2b28;
}

.processing-status {
  min-height: 38rpx;
  font-size: 26rpx;
  line-height: 1.45;
  color: #6a6f66;
  text-align: center;
}

.processing-progress-wrap {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
}

.processing-progress-track {
  position: relative;
  width: 100%;
  height: 22rpx;
  border-radius: 999rpx;
  background: rgba(29, 92, 75, 0.1);
  overflow: hidden;
  box-shadow: inset 0 0 0 2rpx rgba(29, 92, 75, 0.08);
}

.processing-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #1d5c4b 0%, #d66a4d 58%, #f6d26b 100%);
  background-size: 180% 100%;
  animation: progress-shimmer 2s linear infinite;
  transition: width 0.28s ease;
}

.processing-progress-spark {
  position: absolute;
  top: 50%;
  width: 30rpx;
  height: 30rpx;
  margin-top: -15rpx;
  margin-left: -15rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 0 0 6rpx rgba(246, 210, 107, 0.22), 0 0 18rpx rgba(214, 106, 77, 0.45);
  transition: left 0.28s ease;
}

.processing-progress-row {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.processing-progress-label {
  font-size: 24rpx;
  color: #6a6f66;
}

.file-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 32rpx;
  background: rgba(157, 92, 73, 0.08);
  border-radius: 24rpx;
}

.file-preview__icon {
  font-size: 96rpx;
}

.file-preview__name {
  font-size: 28rpx;
  line-height: 1.4;
  color: #5a4a3a;
  font-weight: 600;
  text-align: center;
  word-break: break-all;
}

.media-preview__video {
  width: 100%;
  height: 480rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #111111;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
}

@keyframes progress-shimmer {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

.processing-progress-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #1d5c4b;
}

.chip-expand {
  background: transparent;
  border: 2rpx dashed rgba(0, 0, 0, 0.2);
}

.chip-expand.chip-active {
  background: rgba(29, 92, 75, 0.08);
  border-color: rgba(29, 92, 75, 0.3);
}

/* 音视频格式分组样式 */
.format-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  width: 100%;
  margin-bottom: 20rpx;
}

.format-group:last-child {
  margin-bottom: 0;
}

.format-group-label {
  display: block;
  font-size: 24rpx;
  color: #6a6f66;
  font-weight: 600;
  padding-left: 4rpx;
}

.format-group-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

/* PDF合并专用样式 */
.pdf-merge-container {
  margin-top: 20rpx;
}

.pdf-merge-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.pdf-merge-title {
  font-size: 28rpx;
  color: #1f2b28;
  font-weight: 600;
}

.pdf-merge-swiper {
  width: 100%;
  height: 400rpx;
  border-radius: 24rpx;
  background: rgba(244, 240, 233, 0.9);
  margin-top: 16rpx;
}

.pdf-preview-card {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.pdf-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.pdf-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.pdf-name {
  font-size: 28rpx;
  color: #1f2b28;
  font-weight: 600;
  text-align: center;
  word-break: break-all;
}

.pdf-meta {
  font-size: 24rpx;
  color: #6a6f66;
}

.pdf-merge-thumbs {
  width: 100%;
  margin-top: 20rpx;
}

.pdf-merge-thumbs__list {
  display: flex;
  gap: 12rpx;
  padding: 8rpx 0;
}

.pdf-merge-thumb {
  position: relative;
  width: 120rpx;
  height: 160rpx;
  border-radius: 16rpx;
  overflow: hidden;
  border: 4rpx solid transparent;
  transition: all 0.2s ease;
  background: rgba(244, 240, 233, 0.9);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.pdf-merge-thumb--active {
  border-color: #1d5c4b;
}

.pdf-thumb-icon {
  font-size: 48rpx;
}

.pdf-thumb-name {
  font-size: 24rpx;
  color: #1f2b28;
  margin-top: 8rpx;
}

.pdf-thumb-delete {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #dc4c46;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  box-shadow: 0 4rpx 12rpx rgba(220, 76, 70, 0.4);
}

.pdf-thumb-delete-icon {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: bold;
  line-height: 1;
}

.pdf-merge-sort-hint {
  margin-top: 20rpx;
  padding: 16rpx 24rpx;
  background: rgba(29, 92, 75, 0.08);
  border-radius: 16rpx;
  text-align: center;
}

.sort-hint-text {
  font-size: 24rpx;
  color: #1d5c4b;
}

.more-colors-wrap {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid rgba(0, 0, 0, 0.06);
}

.image-to-pdf-container {
  margin-top: 20rpx;
}

.image-to-pdf-swiper {
  width: 100%;
  height: 480rpx;
  border-radius: 24rpx;
  margin-top: 16rpx;
  background: rgba(244, 240, 233, 0.9);
}

.image-to-pdf-swiper__image {
  width: 100%;
  height: 100%;
}

.image-to-pdf-thumbs {
  width: 100%;
  margin-top: 20rpx;
}

.image-to-pdf-thumbs__list {
  display: flex;
  gap: 12rpx;
  padding: 8rpx 0;
}

.image-to-pdf-thumb {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  overflow: hidden;
  border: 4rpx solid transparent;
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.image-to-pdf-thumb--active {
  border-color: #1d5c4b;
}

.image-to-pdf-thumb__image {
  width: 100%;
  height: 100%;
  background: rgba(244, 240, 233, 0.9);
}

.image-to-pdf-thumb__index {
  position: absolute;
  bottom: 6rpx;
  right: 6rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.6);
  color: #ffffff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-to-pdf-actions {
  margin-top: 20rpx;
  text-align: center;
}

.image-to-pdf-hint {
  font-size: 24rpx;
  color: #1d5c4b;
}

.image-to-pdf-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.image-to-pdf-delete-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(220, 76, 70, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.image-to-pdf-delete-btn:active {
  background: rgba(220, 76, 70, 0.3);
  transform: scale(0.95);
}

.image-to-pdf-delete-icon {
  font-size: 32rpx;
  color: #dc4c46;
  font-weight: bold;
}

.image-to-pdf-thumb__delete {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #dc4c46;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  box-shadow: 0 4rpx 12rpx rgba(220, 76, 70, 0.4);
}

.image-to-pdf-thumb__delete-icon {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: bold;
  line-height: 1;
}
