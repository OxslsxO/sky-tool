  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #636E72;
}

.tool-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  opacity: 0;
  pointer-events: none;
}

.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.loading-spinner {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.loading-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #C8956C;
  animation: loading-bounce 1.4s ease-in-out infinite both;
}

.loading-dot:nth-child(1) {
  animation-delay: -0.32s;
  background: #C8956C;
}

.loading-dot:nth-child(2) {
  animation-delay: -0.16s;
  background: #D4A574;
}

.loading-dot:nth-child(3) {
  animation-delay: 0s;
  background: #7DB9A8;
}

@keyframes loading-bounce {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.5;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

.loading-text {
  font-size: 28rpx;
  color: #C8956C;
}

.chip-color {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.chip-color__dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 8rpx 14rpx 8rpx 14rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.1);
  flex-shrink: 0;
}

/* ===== 处理中弹�?- 有机风格 ===== */
.processing-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 251, 247, 0.9);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.processing-panel {
  width: 580rpx;
  min-height: 520rpx;
  padding: 48rpx 40rpx 42rpx;
  border-radius: 32rpx 48rpx 36rpx 40rpx;
  background: #FFFFFF;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 22rpx;
  box-shadow:
    0 28rpx 90rpx rgba(200, 149, 108, 0.2),
    0 8rpx 24rpx rgba(200, 149, 108, 0.1);
  overflow: hidden;
  border: 2rpx solid rgba(200, 149, 108, 0.08);
}

.processing-stage {
  position: relative;
  width: 220rpx;
  height: 190rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.processing-orbit {
  position: relative;
  width: 174rpx;
  height: 174rpx;
}

.processing-orbit__ring {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  width: 150rpx;
  height: 150rpx;
  border: 4rpx solid rgba(200, 149, 108, 0.12);
  border-top-color: #C8956C;
  border-right-color: #D4A574;
  border-radius: 50%;
  animation: processing-spin 2.4s linear infinite;
}

.processing-orbit__ring--second {
  top: 34rpx;
  left: 34rpx;
  width: 106rpx;
  height: 106rpx;
  border-color: rgba(253, 203, 110, 0.12);
  border-bottom-color: #D4A574;
  border-left-color: #7DB9A8;
  animation-direction: reverse;
  animation-duration: 1.8s;
}

.processing-orbit__core {
  position: absolute;
  top: 53rpx;
  left: 47rpx;
  width: 80rpx;
  height: 68rpx;
  padding: 12rpx;
  border-radius: 18rpx 26rpx 18rpx 26rpx;
  background: #2D3436;
  box-shadow: 0 14rpx 28rpx rgba(45, 52, 54, 0.2);
  box-sizing: border-box;
}

.processing-core__bar {
  height: 8rpx;
  border-radius: 999rpx;
  background: #C8956C;
  animation: processing-bars 1.2s ease-in-out infinite;
}

.processing-core__bar + .processing-core__bar {
  margin-top: 8rpx;
}

.processing-core__bar--one {
  width: 100%;
}

.processing-core__bar--two {
  width: 70%;
  animation-delay: 0.14s;
  background: #D4A574;
}

.processing-core__bar--three {
  width: 46%;
  animation-delay: 0.28s;
  background: #7DB9A8;
}

.processing-chip {
  position: absolute;
  width: 22rpx;
  height: 22rpx;
  border-radius: 7rpx 12rpx 7rpx 12rpx;
  background: #C8956C;
  box-shadow: 0 8rpx 18rpx rgba(200, 149, 108, 0.28);
  animation: processing-float 1.9s ease-in-out infinite;
}

.processing-chip--one {
  top: 20rpx;
  left: 18rpx;
}

.processing-chip--two {
  right: 10rpx;
  top: 70rpx;
  width: 18rpx;
  height: 18rpx;
  background: #D4A574;
  animation-delay: 0.24s;
}

.processing-chip--three {
  left: 52rpx;
  bottom: 8rpx;
  width: 16rpx;
  height: 16rpx;
  background: #7DB9A8;
  animation-delay: 0.48s;
}

@keyframes processing-spin {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

@keyframes processing-bars {
  0%, 100% {
    opacity: 0.55;
    transform: scaleX(0.7);
    transform-origin: left center;
  }
  50% {
    opacity: 1;
    transform: scaleX(1);
    transform-origin: left center;
  }
}

@keyframes processing-float {
  0%, 100% {
    transform: translate3d(0, 0, 0) rotate(0deg);
  }
  50% {
    transform: translate3d(0, -16rpx, 0) rotate(10deg);
  }
}

.processing-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #2D3436;
}

.processing-status {
  min-height: 38rpx;
  font-size: 26rpx;
  line-height: 1.45;
  color: #B2BEC3;
  text-align: center;
}

.processing-progress-wrap {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
}

.processing-progress-track {
  position: relative;
  width: 100%;
  height: 22rpx;
  border-radius: 999rpx;
  background: rgba(200, 149, 108, 0.08);
  overflow: hidden;
  box-shadow: inset 0 0 0 2rpx rgba(200, 149, 108, 0.04);
}

.processing-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #C8956C 0%, #D4A574 58%, #7DB9A8 100%);
  background-size: 180% 100%;
  animation: progress-shimmer 2s linear infinite;
  transition: width 0.28s ease;
}

.processing-progress-spark {
  position: absolute;
  top: 50%;
  width: 30rpx;
  height: 30rpx;
  margin-top: -15rpx;
  margin-left: -15rpx;
  border-radius: 50%;
  background: #FFFFFF;
  box-shadow: 0 0 0 6rpx rgba(0, 184, 148, 0.15), 0 0 18rpx rgba(200, 149, 108, 0.2);
  transition: left 0.28s ease;
}

.processing-progress-row {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.processing-progress-label {
  font-size: 24rpx;
  color: #B2BEC3;
}

.processing-actions {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-top: 8rpx;
}

.processing-btn-background {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 18rpx 44rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #C8956C, #D4A574);
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(200, 149, 108, 0.3);
}

.processing-btn-background__icon {
  font-size: 24rpx;
  color: #FFFFFF;
}

.processing-btn-background__text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 700;
  letter-spacing: 2rpx;
}



.file-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 32rpx;
  background: #FFF9F6;
  border-radius: 24rpx 36rpx 28rpx 32rpx;
  border: 2rpx solid rgba(200, 149, 108, 0.08);
}

.file-preview__icon {
  font-size: 96rpx;
}

.file-preview__name {
  font-size: 28rpx;
  line-height: 1.4;
  color: #2D3436;
  font-weight: 600;
  text-align: center;
  word-break: break-all;
}

.media-preview__video {
  width: 100%;
  height: 480rpx;
  border-radius: 24rpx 36rpx 28rpx 32rpx;
  overflow: hidden;
  background: #2a2a2a;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

@keyframes progress-shimmer {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

.processing-progress-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #C8956C;
}

.chip-expand {
  background: transparent;
  border: 2rpx dashed rgba(200, 149, 108, 0.25);
  color: #2D3436;
}

.chip-expand.chip-active {
  background: linear-gradient(135deg, #C8956C 0%, #D4A574 100%);
  border-color: transparent;
  color: #FFFFFF;
  box-shadow: 0 8rpx 28rpx rgba(200, 149, 108, 0.35);
}

.format-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  width: 100%;
  margin-bottom: 20rpx;
}

.format-group:last-child {
  margin-bottom: 0;
}

.format-group-label {
  display: block;
  font-size: 24rpx;
  color: #B2BEC3;
  font-weight: 600;
  padding-left: 4rpx;
}

.format-group-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

/* ===== PDF合并专用样式 ===== */
.pdf-merge-container {
  margin-top: 20rpx;
}

.pdf-merge-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.pdf-merge-title {
  font-size: 28rpx;
  color: #2D3436;
  font-weight: 800;
}

.pdf-merge-swiper {
  width: 100%;
  height: 400rpx;
  border-radius: 24rpx 36rpx 28rpx 32rpx;
  background: #FFF9F6;
  margin-top: 16rpx;
  border: 2rpx solid rgba(200, 149, 108, 0.08);
  overflow: hidden;
}

.pdf-preview-card {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.pdf-icon {
  font-size: 120rpx;
}

.pdf-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.pdf-name {
  font-size: 28rpx;
  color: #2D3436;
  font-weight: 600;
  text-align: center;
  width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.pdf-meta {
  font-size: 24rpx;
  color: #B2BEC3;
}

.pdf-merge-thumbs {
  width: 100%;
  margin-top: 20rpx;
}

.pdf-merge-thumbs__list {
  display: flex;
  gap: 12rpx;
  padding: 8rpx 0;
}

.pdf-merge-thumb {
  position: relative;
  width: 120rpx;
  height: 160rpx;
  border-radius: 16rpx 24rpx 16rpx 24rpx;
  overflow: hidden;
  border: 4rpx solid transparent;
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  background: #FFF9F6;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(200, 149, 108, 0.06);
}

.pdf-merge-thumb--active {
  border-color: #C8956C;
  box-shadow: 0 6rpx 20rpx rgba(200, 149, 108, 0.15);
  transform: translateY(-2rpx);
}

.pdf-merge-thumb--dragging {
  transform: scale(1.05);
  z-index: 100;
  box-shadow: 0 8rpx 24rpx rgba(200, 149, 108, 0.25);
  opacity: 0.5;
}

.pdf-merge-thumb--highlight {
  border-color: #E07B39;
  border-width: 4rpx;
  box-shadow: 0 0 20rpx rgba(224, 123, 57, 0.4);
  transform: scale(1.05);
  background: rgba(224, 123, 57, 0.08);
}

/* 悬浮拖拽元素 */
.pdf-merge-floating-drag {
  position: fixed;
  z-index: 9999;
  pointer-events: none;
  width: 150rpx;
  height: 150rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.3);
  transform: scale(1.1);
  opacity: 0.95;
  background: #FFFFFF;
  border: 2rpx solid rgba(200, 149, 108, 0.15);
}

.pdf-merge-floating-content {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pdf-merge-floating-icon {
  font-size: 80rpx;
}

.pdf-thumb-icon {
  font-size: 48rpx;
}

.pdf-thumb-name {
  font-size: 22rpx;
  color: #2D3436;
  margin-top: 8rpx;
  width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
  padding: 0 8rpx;
  box-sizing: border-box;
  font-weight: 500;
}

.pdf-thumb-delete {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #C8956C;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  box-shadow: 0 4rpx 12rpx rgba(200, 149, 108, 0.4);
  transition: all 0.3s ease;
}

.pdf-thumb-delete:active {
  transform: scale(0.9);
}

.pdf-thumb-delete-icon {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: bold;
  line-height: 1;
}

.pdf-merge-sort-hint {
  margin-top: 20rpx;
