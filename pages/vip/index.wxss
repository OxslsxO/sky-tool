.plan-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.plan-card {
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.94), rgba(244, 240, 233, 0.96));
}

.plan-card--recommended {
  background: linear-gradient(145deg, #e3efe9 0%, #f4faf6 64%, #ffffff 100%);
}

.plan-card__name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2d29;
}

.plan-card__badge {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(29, 92, 75, 0.1);
  color: #1d5c4b;
  font-size: 22rpx;
}

.plan-card__price {
  display: block;
  margin-top: 18rpx;
  font-size: 48rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #1d5c4b;
}

.plan-card__period {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #7a776d;
}

.plan-card__copy {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #666b64;
}
