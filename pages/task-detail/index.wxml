<view class="container" wx:if="{{task}}">
  <view class="hero task-hero task-hero--{{task.status}}">
    <text class="eyebrow">Task Detail</text>
    <text class="hero-title">{{task.tool.name}}</text>
    <text class="hero-copy">{{task.resultHeadline}}</text>

    <view class="hero-stat-row">
      <view class="hero-stat">
        <text class="hero-stat-value">{{task.statusText}}</text>
        <text class="hero-stat-label">当前状态</text>
      </view>
      <view class="hero-stat">
        <text class="hero-stat-value">{{task.createdAtText}}</text>
        <text class="hero-stat-label">创建时间</text>
      </view>
    </view>

    <view class="progress-shell" wx:if="{{task.status === 'processing'}}">
      <view class="progress-track">
        <view class="progress-fill" style="width: {{task.progress}}%;"></view>
      </view>
      <text class="progress-text">预计很快完成，当前进度 {{task.progress}}%</text>
    </view>
  </view>

  <view class="section">
    <view class="card detail-card">
      <text class="detail-card__title" wx:if="{{task.status !== 'expired'}}">本次结果</text>
      <text class="detail-card__title" wx:else>任务已过期</text>
      <text class="detail-card__copy" wx:if="{{task.status !== 'expired'}}">{{task.finalDetail}}</text>
      <text class="detail-card__copy" wx:else>该任务已超过{{taskRetentionDays}}天保留期，结果文件已不再可用。</text>
      <view class="detail-card__text-result" wx:if="{{task.status === 'success' && task.resultType === 'text' && task.resultText && task.status !== 'expired'}}">
        <scroll-view class="detail-card__text-scroll" scroll-y>
          <text class="detail-card__text-content" selectable="true" user-select="true">{{task.resultText}}</text>
        </scroll-view>
        <view class="detail-card__text-actions">
          <view class="btn-ghost detail-card__copy-btn" bindtap="copyResult">复制全部文字</view>
        </view>
      </view>
      <image class="detail-card__preview" wx:if="{{task.previewPath && task.resultType === 'image' && task.status !== 'expired'}}" src="{{task.previewPath}}" mode="aspectFit" bindtap="previewResult"></image>
      <view class="audio-player" wx:if="{{task.status === 'success' && isAudioTask && task.status !== 'expired'}}" bindtap="toggleAudioPlay">
        <view class="audio-cover">
          <text class="audio-play-icon">{{isPlaying ? '⏸' : '▶'}}</text>
        </view>
        <view class="audio-info">
          <view class="audio-name">{{task.outputName || '音频文件'}}</view>
          <view class="audio-meta">{{audioMetaText}}</view>
        </view>
      </view>
      <view class="detail-card__document" wx:if="{{task.status === 'success' && task.resultType === 'document' && !isAudioTask && !task.previewPath && task.status !== 'expired'}}" bindtap="openDocumentResult">
        <view class="detail-card__document-icon">📄</view>
        <view class="detail-card__document-info">
          <view class="detail-card__document-name">{{task.outputName || '文档文件'}}</view>
          <view class="detail-card__document-hint">点击打开文件</view>
        </view>
      </view>
      <view class="detail-card__meta" wx:if="{{task.metaLines.length && task.status !== 'expired'}}">
        <text class="detail-card__meta-line" wx:for="{{task.metaLines}}" wx:key="*this">{{item}}</text>
      </view>
      <view class="detail-card__attachments" wx:if="{{task.attachments.length && task.status !== 'expired'}}">
        <view class="detail-card__attachment" wx:for="{{task.attachments}}" wx:key="url" data-url="{{item.url}}" bindtap="openAttachment">
          <text class="detail-card__attachment-name">{{item.label || item.name}}</text>
          <text class="detail-card__attachment-link">打开文件</text>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="card action-card">
      <view class="action-card__buttons">
        <view class="btn-secondary action-card__button" wx:if="{{(task.outputPath || task.remoteUrl) && task.status !== 'expired'}}" bindtap="saveResult">保存</view>
        <view class="btn-secondary action-card__button" wx:if="{{task.status === 'success' && task.resultType === 'document' && !task.outputPath && !task.remoteUrl && task.status !== 'expired'}}" bindtap="openDocumentResult">打开文件</view>
        <view class="btn-ghost action-card__button" wx:if="{{task.remoteUrl && task.status !== 'expired'}}" bindtap="copyDownloadLink">复制链接</view>
        <view class="btn-ghost action-card__button" bindtap="openTasks">返回</view>
      </view>
    </view>
  </view>
  <bg-task-float />
</view>
