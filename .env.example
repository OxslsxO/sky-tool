PDF_SERVICES_CLIENT_ID=your-adobe-client-id
PDF_SERVICES_CLIENT_SECRET=your-adobe-client-secret
# Optional: US or EU
PDF_SERVICES_REGION=US
# Optional: OCR language used during Export PDF, for example zh-CN, en-US, ja-JP
PDF_SERVICES_OCR_LOCALE=zh-CN
# Optional: Adobe SDK request timeout in milliseconds
PDF_SERVICES_TIMEOUT_MS=120000

# Optional: Baidu OCR. When configured, OCR uses Baidu first and falls back to Tesseract.
BAIDU_OCR_API_KEY=your-baidu-ocr-api-key
BAIDU_OCR_SECRET_KEY=your-baidu-ocr-secret-key
# Optional: accurate_basic is higher accuracy; general_basic is usually cheaper/faster.
BAIDU_OCR_ENDPOINT=https://aip.baidubce.com/rest/2.0/ocr/v1/accurate_basic

# Optional: Photo ID model settings for memory-constrained environments (e.g., Render free tier)
# Set to 'true' to disable ONNX model loading and use fallback methods only
PHOTO_ID_DISABLE_MODEL=false
# Optional: Warm up model on startup (may cause memory issues on low-memory instances)
PHOTO_ID_WARM_MODEL=false
