.search-section {
  padding: 24rpx 0 32rpx;
}

.search-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.search-greeting {
  font-size: 38rpx;
  font-weight: 900;
  color: #2D3436;
  letter-spacing: -0.5rpx;
}

/* жңүжңәеӨҙеғҸ - ж°ҙж»ҙеҪўзҠ¶ */
.search-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50% 40% 50% 40%;
  background: linear-gradient(135deg, #C8956C 0%, #D4A574 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(200, 149, 108, 0.35);
  border: 3rpx solid rgba(255, 255, 255, 0.5);
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.search-avatar:active {
  transform: scale(0.9) rotate(-10deg);
  border-radius: 40% 50% 40% 50%;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50% 40% 50% 40%;
}

.avatar-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
}

/* жңүжңәжҗңзҙўжЎ?*/
.search-shell--primary {
  position: relative;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 28rpx;
  border-radius: 24rpx 36rpx 28rpx 32rpx;
  background: #FFFFFF;
  box-shadow:
    0 8rpx 32rpx rgba(200, 149, 108, 0.12),
    0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid rgba(200, 149, 108, 0.08);
  transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.search-shell--primary:focus-within {
  box-shadow:
    0 12rpx 40rpx rgba(200, 149, 108, 0.2),
    0 0 0 3rpx rgba(200, 149, 108, 0.1);
  transform: translateY(-3rpx) scale(1.01);
  border-radius: 28rpx 40rpx 32rpx 36rpx;
}

.search-icon {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.search-icon-text {
  font-size: 34rpx;
}

.search-input--large {
  flex: 1;
  height: 56rpx;
  font-size: 28rpx;
  color: #2D3436;
  font-weight: 500;
}

.search-clear-shell {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: rgba(200, 149, 108, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.search-clear-shell:active {
  background: rgba(200, 149, 108, 0.15);
  transform: scale(0.85) rotate(90deg);
}

.search-clear {
  font-size: 26rpx;
  color: #C8956C;
  font-weight: 700;
}

.tools-section {
  margin-top: 8rpx;
}

.tools-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.tools-title-group {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.tools-count {
  font-size: 24rpx;
  color: #B2BEC3;
}

/* и§ҶеӣҫеҲҮжҚў - жңүжңәеҪўзҠ¶ */
.view-toggle {
  display: flex;
  gap: 8rpx;
  padding: 6rpx;
  border-radius: 20rpx 28rpx 20rpx 28rpx;
  background: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(200, 149, 108, 0.1);
  border: 2rpx solid rgba(200, 149, 108, 0.08);
}

.view-toggle-btn {
  width: 68rpx;
  height: 56rpx;
  border-radius: 16rpx 24rpx 16rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.view-toggle-btn:active {
  transform: scale(0.9) rotate(-5deg);
}

.view-toggle-btn--active {
  background: linear-gradient(135deg, #C8956C 0%, #D4A574 100%);
  box-shadow: 0 4rpx 16rpx rgba(200, 149, 108, 0.35);
  border-radius: 20rpx 16rpx 20rpx 16rpx;
}

.view-toggle-icon {
  font-size: 30rpx;
  color: #B2BEC3;
  font-weight: 700;
}

.view-toggle-btn--active .view-toggle-icon {
  color: #FFFFFF;
}

.category-filter {
  margin-bottom: 24rpx;
}

.category-scroll {
  width: 100%;
}

.category-list {
  display: flex;
  gap: 14rpx;
  padding: 4rpx 0;
}

/* жңүжңәеҲҶзұ»ж Үзӯҫ */
.category-chip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 26rpx;
  border-radius: 20rpx 28rpx 20rpx 28rpx;
  background: #FFFFFF;
  flex-shrink: 0;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 0 4rpx 16rpx rgba(200, 149, 108, 0.1);
  border: 2rpx solid rgba(200, 149, 108, 0.08);
}

.category-chip:active {
  transform: scale(0.95) translateY(-2rpx);
}

.category-chip--active {
  background: linear-gradient(135deg, #C8956C 0%, #D4A574 100%);
  border-color: transparent;
  box-shadow: 0 8rpx 24rpx rgba(200, 149, 108, 0.35);
  transform: translateY(-2rpx);
}

.category-chip-icon {
  font-size: 18rpx;
  font-weight: 800;
}

.category-chip-text {
  font-size: 24rpx;
  color: #2D3436;
  font-weight: 600;
}

.category-chip--active .category-chip-text {
  color: #FFFFFF;
  font-weight: 700;
}

/* ===== жңүжңәе·Ҙе…·зҪ‘ж ј ===== */
.tools-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.tool-grid-item {
  width: 100%;
  min-height: 200rpx;
  border-radius: 24rpx 36rpx 28rpx 32rpx;
  padding: 28rpx 20rpx 22rpx;
  box-sizing: border-box;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  background: #FFFFFF;
  box-shadow:
    0 8rpx 32rpx rgba(200, 149, 108, 0.12),
    0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid rgba(200, 149, 108, 0.06);
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  overflow: hidden;
}

/* иҫ№зјҳжҹ”е’ҢжЁЎзіҠе…үжҷ• */
.tool-grid-item::before {
  content: '';
  position: absolute;
  inset: -2rpx;
  border-radius: 26rpx 38rpx 30rpx 34rpx;
  background: transparent;
  box-shadow:
    0 0 20rpx 4rpx rgba(200, 149, 108, 0.15),
    0 0 40rpx 8rpx rgba(253, 203, 110, 0.1),
    0 0 60rpx 12rpx rgba(0, 184, 148, 0.08);
  opacity: 0;
  transition: opacity 0.4s ease;
  pointer-events: none;
  z-index: -1;
  filter: blur(8rpx);
}

.tool-grid-item:active::before {
  opacity: 1;
}

/* еә•йғЁжҹ”е’Ңе…үжҷ• */
.tool-grid-item::after {
  content: '';
  position: absolute;
  bottom: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80%;
  height: 50rpx;
  border-radius: 50%;
  background: radial-gradient(ellipse at center, var(--glow, rgba(200, 149, 108, 0.12)) 0%, transparent 70%);
  filter: blur(12rpx);
  animation: glow-pulse-item 4s ease-in-out infinite;
  pointer-events: none;
  z-index: 0;
}

@keyframes glow-pulse-item {
  0%, 100% { opacity: 0.4; transform: translateX(-50%) scale(1); }
  50% { opacity: 0.8; transform: translateX(-50%) scale(1.2); }
}

.tool-grid-item--pressed {
  transform: scale(0.94) translateY(4rpx);
  box-shadow: 0 4rpx 16rpx rgba(200, 149, 108, 0.08);
}

.tool-grid-item--hot {
  animation: hotFloat 3s ease-in-out infinite;
}

@keyframes hotFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-4rpx); }
}

.tool-grid-item--hot.tool-grid-item--pressed {
  animation: none;
}

/* иЈ…йҘ°еңҶзҺҜ */
.tool-grid-deco-ring {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(200, 149, 108, 0.15);
  pointer-events: none;
  z-index: 2;
  animation: ring-rotate 8s linear infinite;
}

@keyframes ring-rotate {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* иЈ…йҘ°и„үеҶІзӮ?*/
.tool-grid-deco-dot {
  position: absolute;
  top: 22rpx;
  right: 22rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #C8956C, #D4A574);
  box-shadow: 0 0 8rpx rgba(200, 149, 108, 0.4);
  animation: dotPulse 2.5s ease-in-out infinite;
  pointer-events: none;
  z-index: 3;
}

@keyframes dotPulse {
  0%, 100% { opacity: 0.5; transform: scale(0.9); }
  50% { opacity: 1; transform: scale(1.3); }
}

/* й«ҳе…үеҸҚе°„ */
.tool-grid-shine {
  position: absolute;
  top: -30%;
  right: -30%;
  width: 70%;
  height: 70%;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.5) 0%, transparent 55%);
  pointer-events: none;
  z-index: 1;
}

.tool-grid-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  width: 100%;
}

/* жңүжңәеӣҫж Ү */
.tool-grid-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx 26rpx 18rpx 26rpx;
  background: linear-gradient(135deg, rgba(200, 149, 108, 0.1) 0%, rgba(253, 203, 110, 0.08) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(200, 149, 108, 0.1);
  border: 2rpx solid rgba(200, 149, 108, 0.1);
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  position: relative;
  overflow: hidden;
}

.tool-grid-icon::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.4) 0%, transparent 100%);
  pointer-events: none;
}

.tool-grid-icon--pressed {
  transform: scale(0.88) rotate(-8deg);
  border-radius: 26rpx 18rpx 26rpx 18rpx;
}

.tool-icon-svg {
  width: 38rpx;
  height: 38rpx;
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  position: relative;
  z-index: 1;
}

.tool-icon-svg--pressed {
  transform: scale(1.15) rotate(-12deg);
}

.tool-icon-svg--small {
  width: 40rpx;
  height: 40rpx;
}

.tool-icon-svg--mini {
  width: 32rpx;
  height: 32rpx;
}

.tool-grid-name {
  font-size: 26rpx;
  font-weight: 800;
  color: #2D3436;
  line-height: 1.3;
  letter-spacing: -0.2rpx;
  text-align: center;
}

.tool-grid-usage {
  font-size: 20rpx;
  color: rgba(45, 52, 54, 0.45);
  font-weight: 500;
  text-align: center;
  letter-spacing: 0.3rpx;
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
}

.tool-grid-usage::before {
  content: '';
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: var(--accent, #C8956C);
  opacity: 0.5;
}

.tool-grid-points {
  font-size: 20rpx;
  color: rgba(45, 52, 54, 0.4);
  font-weight: 600;
  text-align: center;
  letter-spacing: 0.5rpx;
  padding: 6rpx 14rpx;
  background: rgba(200, 149, 108, 0.08);
  border-radius: 16rpx 24rpx 16rpx 24rpx;
}

.tool-grid-arrow-icon {
  position: absolute;
  right: 18rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 20rpx;
  color: rgba(45, 52, 54, 0.15);
  font-weight: 800;
  transition: all 0.3s ease;
  z-index: 2;
}

.tool-grid-item--pressed .tool-grid-arrow-icon {
  color: rgba(45, 52, 54, 0.3);
  transform: translateY(-50%) translateX(4rpx);
}

/* ===== жңүжңәеҲ—иЎЁйЎ?===== */
.tools-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tool-list-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 26rpx;
  border-radius: 24rpx 36rpx 28rpx 32rpx;
  background: #FFFFFF;
  box-shadow:
    0 8rpx 32rpx rgba(200, 149, 108, 0.1),
    0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid rgba(200, 149, 108, 0.06);
  transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  overflow: hidden;
}

.tool-list-item:active {
  transform: scale(0.98) translateY(3rpx);
  background: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(200, 149, 108, 0.15);
}

.tool-list-icon-shell {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx 30rpx 22rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 6rpx 20rpx rgba(200, 149, 108, 0.12);
  border: 2rpx solid rgba(200, 149, 108, 0.1);
  background: linear-gradient(135deg, rgba(200, 149, 108, 0.1) 0%, rgba(253, 203, 110, 0.08) 100%);
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.tool-list-item:active .tool-list-icon-shell {
  transform: rotate(-5deg) scale(0.95);
  border-radius: 30rpx 22rpx 30rpx 22rpx;
}

.tool-list-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.tool-list-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.tool-list-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #2D3436;
  letter-spacing: -0.3rpx;
}

.tool-list-badges {
  display: flex;
  gap: 8rpx;
}

.tool-list-badge {
  padding: 6rpx 14rpx;
  border-radius: 16rpx 24rpx 16rpx 24rpx;
  background: linear-gradient(135deg, rgba(200, 149, 108, 0.1) 0%, rgba(253, 203, 110, 0.08) 100%);
  font-size: 20rpx;
  color: #C8956C;
  font-weight: 600;
  border: 2rpx solid rgba(200, 149, 108, 0.1);
}

.tool-list-desc {
  font-size: 24rpx;
  color: #636E72;
  line-height: 1.5;
}

.tool-list-meta {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-wrap: wrap;
}

.tool-list-format,
.tool-list-usage {
  font-size: 22rpx;
  color: #B2BEC3;
  padding: 4rpx 12rpx;
  background: rgba(200, 149, 108, 0.06);
  border-radius: 12rpx 20rpx 12rpx 20rpx;
}

.tool-list-points {
  font-size: 22rpx;
  color: #C8956C;
  font-weight: 600;
  padding: 4rpx 12rpx;
  background: rgba(200, 149, 108, 0.08);
  border-radius: 12rpx 20rpx 12rpx 20rpx;
}

.tool-list-action {
  flex-shrink: 0;
}

.tool-list-arrow {
  font-size: 36rpx;
  color: rgba(45, 52, 54, 0.2);
  font-weight: 300;
  transition: all 0.3s ease;
}

.tool-list-item:active .tool-list-arrow {
  transform: translateX(4rpx);
  color: rgba(45, 52, 54, 0.4);
}

/* ===== д»»еҠЎиҝ·дҪ еҚЎзүҮ ===== */
.task-mini-section {
  margin-top: 28rpx;
}

.task-mini-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-radius: 24rpx 36rpx 28rpx 32rpx;
  background: linear-gradient(135deg, rgba(200, 149, 108, 0.08) 0%, rgba(253, 203, 110, 0.06) 100%);
  border: 2rpx solid rgba(200, 149, 108, 0.1);
  box-shadow: 0 6rpx 24rpx rgba(200, 149, 108, 0.08);
  transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.task-mini-card:active {
  transform: scale(0.98) translateY(2rpx);
  background: linear-gradient(135deg, rgba(200, 149, 108, 0.12) 0%, rgba(253, 203, 110, 0.1) 100%);
}

.task-mini-info {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.task-mini-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #C8956C;
  box-shadow: 0 0 8rpx rgba(200, 149, 108, 0.5);
}

.task-mini-dot--pulse {
  animation: organicPulse 1.5s ease-in-out infinite;
}

@keyframes organicPulse {
  0%, 100% { opacity: 1; transform: scale(1); box-shadow: 0 0 8rpx rgba(200, 149, 108, 0.5); }
  50% { opacity: 0.5; transform: scale(1.4); box-shadow: 0 0 16rpx rgba(200, 149, 108, 0.7); }
}

.task-mini-text {
  font-size: 26rpx;
  color: #C8956C;
  font-weight: 600;
}

.task-mini-arrow {
  font-size: 32rpx;
  color: #C8956C;
  font-weight: 300;
  transition: all 0.3s ease;
}

.task-mini-card:active .task-mini-arrow {
  transform: translateX(4rpx);
}

/* ===== жңҖиҝ‘дҪҝз”?===== */
.recent-tools-scroll {
  margin: 0 -28rpx;
  padding: 0 28rpx;
}

.recent-tools-row {
  display: flex;
  gap: 20rpx;
  padding: 4rpx 0;
}

.recent-tool-mini {
