  <view class="section">
    <view class="card member-card">
      <view class="member-header">
        <view class="member-avatar-shell">
          <image wx:if="{{user.avatarUrl}}" class="member-avatar" src="{{user.avatarUrl}}" mode="aspectFill" />
          <text wx:else class="member-avatar-text">{{user.nickname[0]}}</text>
        </view>
        <view class="member-info">
          <text class="member-name">{{user.nickname}}</text>
        </view>
        <view class="member-points-shell">
          <text class="member-points-value">{{user.points}}</text>
          <text class="member-points-label">积分</text>
        </view>
      </view>

      <view class="member-stats">
        <view class="member-stat">
          <text class="member-stat-value">{{user.freeQuota}}</text>
          <text class="member-stat-label">剩余免费</text>
        </view>
        <view class="member-stat-divider"></view>
        <view class="member-stat">
          <text class="member-stat-value">{{taskCount}}</text>
          <text class="member-stat-label">已完成任务</text>
        </view>
      </view>

      <view class="member-actions">
        <view class="btn-ghost member-button" bindtap="goTasks">任务中心</view>
      </view>
    </view>
  </view>
</view>
