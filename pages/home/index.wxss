}

.tool-list-desc {
  font-size: 26rpx;
  color: #626761;
  line-height: 1.5;
}

.tool-list-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.tool-list-format {
  font-size: 22rpx;
