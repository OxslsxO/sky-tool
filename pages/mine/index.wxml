<view class="container">
  <view class="hero mine-hero">
    <text class="eyebrow">Profile</text>
    <text class="hero-title">{{user.nickname || 'Toolbox User'}}</text>

    <view class="hero-stat-row">
      <view class="hero-stat" bindtap="openVip">
        <text class="hero-stat-value">{{memberStatus.active ? memberStatus.plan : '未开通'}}</text>
        <text class="hero-stat-label">会员</text>
      </view>
      <view class="hero-stat" bindtap="openVip">
        <text class="hero-stat-value">{{user.points}}</text>
        <text class="hero-stat-label">积分</text>
      </view>
      <view class="hero-stat">
        <text class="hero-stat-value">{{taskCount}}</text>
        <text class="hero-stat-label">任务</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="card vip-entry" bindtap="openVip">
      <view class="vip-entry__left">
        <text class="vip-entry__title">{{memberStatus.active ? '会员中心' : '开通会员'}}</text>
        <text class="vip-entry__copy">{{memberStatus.active ? '剩余' + memberStatus.remainingDays + '天 · 积分' + user.points : '享受全部工具免费使用'}}</text>
      </view>
      <text class="vip-entry__arrow">›</text>
    </view>
  </view>

  <!-- 完全移除账户卡片 -->
  <!-- 数据恢复功能暂时隐藏 -->
  
  <!-- 如果后续需要恢复功能，可以在这里添加 -->


  <view class="section" wx:if="{{favorites.length}}">
    <view class="section-head">
      <view>
        <text class="eyebrow">Favorites</text>
        <text class="section-title">My Favorites</text>
      </view>
    </view>

    <view class="grid-two">
      <view class="grid-item" wx:for="{{favorites}}" wx:key="id">
        <tool-card tool="{{item}}" compact="{{true}}" bindselect="handleToolSelect" />
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{recents.length}}">
    <view class="section-head">
      <view>
        <text class="eyebrow">Recent</text>
        <text class="section-title">Recently Used</text>
      </view>
    </view>

    <view class="grid-two">
      <view class="grid-item" wx:for="{{recents}}" wx:key="id">
        <tool-card tool="{{item}}" compact="{{true}}" bindselect="handleToolSelect" />
      </view>
    </view>
  </view>
</view>
