.search-section {
  padding: 24rpx 0 32rpx;
}

.search-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.search-greeting {
  font-size: 40rpx;
  font-weight: 700;
  color: #1e2d29;
}

.search-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1d5c4b 0%, #3c7d68 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}

.search-shell--primary {
  position: relative;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 28rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f8faf9 100%);
  box-shadow: 0 12rpx 40rpx rgba(35, 46, 40, 0.1);
  border: 2rpx solid rgba(29, 92, 75, 0.12);
  transition: all 0.3s ease;
}

.search-shell--primary:focus-within {
  box-shadow: 0 16rpx 48rpx rgba(29, 92, 75, 0.15);
  border-color: rgba(29, 92, 75, 0.2);
  transform: translateY(-2rpx);
}

.search-icon {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.search-icon-text {
  font-size: 36rpx;
}

.search-input--large {
  flex: 1;
  height: 56rpx;
  font-size: 30rpx;
  color: #1d2421;
  font-weight: 500;
}

.search-clear-shell {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: rgba(29, 92, 75, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.search-clear-shell:active {
  background: rgba(29, 92, 75, 0.2);
  transform: scale(0.9);
}

.search-clear {
  font-size: 28rpx;
  color: #1d5c4b;
  font-weight: 700;
}

.tools-section {
  margin-top: 8rpx;
}

.tools-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.tools-title-group {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.tools-count {
  font-size: 26rpx;
  color: #9ba096;
}

.view-toggle {
  display: flex;
  gap: 8rpx;
  padding: 6rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 2rpx solid rgba(29, 92, 75, 0.1);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}

.view-toggle-btn {
  width: 72rpx;
  height: 60rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.view-toggle-btn:active {
  transform: scale(0.95);
}

.view-toggle-btn--active {
  background: linear-gradient(135deg, #1d5c4b 0%, #2d7a62 100%);
  box-shadow: 0 4rpx 12rpx rgba(29, 92, 75, 0.3);
}

.view-toggle-icon {
  font-size: 32rpx;
  color: #7a776d;
  font-weight: 700;
}

.view-toggle-btn--active .view-toggle-icon {
  color: #ffffff;
}

.category-filter {
  margin-bottom: 24rpx;
}

.category-scroll {
  width: 100%;
}

.category-list {
  display: flex;
  gap: 16rpx;
  padding: 4rpx 0;
}

.category-chip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 2rpx solid rgba(29, 92, 75, 0.1);
  flex-shrink: 0;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}

.category-chip:active {
  transform: scale(0.95);
}

.category-chip--active {
  background: linear-gradient(135deg, #1d5c4b 0%, #2d7a62 100%);
  border-color: transparent;
  box-shadow: 0 8rpx 24rpx rgba(29, 92, 75, 0.3);
}

.category-chip-icon {
  font-size: 20rpx;
  font-weight: 800;
}

.category-chip-text {
  font-size: 26rpx;
  color: #5d6158;
  font-weight: 600;
}

.category-chip--active .category-chip-text {
  color: #ffffff;
  font-weight: 700;
}

.tools-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.tool-grid-item {
  width: 100%;
  min-height: 200rpx;
  border-radius: 24rpx;
  padding: 28rpx 20rpx 22rpx;
  box-sizing: border-box;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  box-shadow:
    0 1rpx 2rpx rgba(0, 0, 0, 0.04),
    0 4rpx 8rpx rgba(0, 0, 0, 0.04),
    0 8rpx 16rpx rgba(0, 0, 0, 0.04),
    0 16rpx 32rpx rgba(0, 0, 0, 0.03);
  transition: all 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
}

.tool-grid-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 100%;
  background: linear-gradient(180deg, rgba(255,255,255,0.4) 0%, rgba(255,255,255,0) 40%);
  pointer-events: none;
  z-index: 1;
}

.tool-grid-item::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.8), transparent);
  pointer-events: none;
  z-index: 2;
}

.tool-grid-item--pressed {
  transform: scale(0.94) translateY(2rpx);
  box-shadow:
    0 1rpx 2rpx rgba(0, 0, 0, 0.03),
    0 2rpx 4rpx rgba(0, 0, 0, 0.03);
}

.tool-grid-item--hot {
  animation: hotFloat 3s ease-in-out infinite;
}

.tool-grid-item--hot .tool-grid-accent-bar {
  opacity: 1;
}

@keyframes hotFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-3rpx); }
}

.tool-grid-item--hot.tool-grid-item--pressed {
  animation: none;
}

.tool-grid-accent-bar {
  position: absolute;
  top: 0;
  left: 20rpx;
  right: 20rpx;
  height: 3rpx;
  border-radius: 0 0 4rpx 4rpx;
  background: linear-gradient(90deg, transparent, var(--accent, rgba(255,255,255,0.5)), transparent);
  opacity: 0.6;
  pointer-events: none;
  z-index: 3;
}

.tool-grid-glow {
  position: absolute;
  bottom: -30rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 70%;
  height: 60rpx;
  border-radius: 50%;
  background: radial-gradient(ellipse at center, var(--glow, rgba(0,0,0,0.06)) 0%, transparent 70%);
  animation: glowPulse 3s ease-in-out infinite;
  pointer-events: none;
  z-index: 0;
}

@keyframes glowPulse {
  0%, 100% { opacity: 0.5; transform: translateX(-50%) scale(1); }
  50% { opacity: 1; transform: translateX(-50%) scale(1.2); }
}

.tool-grid-ripple {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 20rpx;
  height: 20rpx;
  margin-left: -10rpx;
  margin-top: -10rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.7) 0%, transparent 70%);
  opacity: 0;
  pointer-events: none;
  z-index: 4;
}

.tool-grid-ripple--active {
  animation: rippleBurst 0.5s ease-out forwards;
}

@keyframes rippleBurst {
  0% { transform: scale(1); opacity: 0.9; }
  100% { transform: scale(30); opacity: 0; }
}

.tool-grid-shine {
  position: absolute;
  top: -30%;
  right: -30%;
  width: 70%;
  height: 70%;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.3) 0%, transparent 55%);
  pointer-events: none;
  z-index: 1;
}

.tool-grid-deco-ring {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  pointer-events: none;
  z-index: 2;
}

.tool-grid-deco-dot {
  position: absolute;
  top: 22rpx;
  right: 22rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e89a5f, #d66a4d);
  box-shadow: 0 0 6rpx rgba(214, 106, 77, 0.4);
  animation: dotPulse 2.5s ease-in-out infinite;
  pointer-events: none;
  z-index: 3;
}

@keyframes dotPulse {
  0%, 100% { opacity: 0.5; transform: scale(0.9); }
  50% { opacity: 1; transform: scale(1.2); }
}

.tool-grid-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  width: 100%;
}

.tool-grid-icon {
  width: 68rpx;
  height: 68rpx;
  border-radius: 20rpx;
  background: linear-gradient(145deg, rgba(255,255,255,0.9) 0%, rgba(255,255,255,0.5) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 2rpx 8rpx rgba(0,0,0,0.04),
    0 4rpx 12rpx rgba(0,0,0,0.03),
    inset 0 1rpx 0 rgba(255,255,255,0.9);
  border: 1rpx solid rgba(255,255,255,0.7);
  transition: all 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  position: relative;
  overflow: hidden;
}

.tool-grid-icon::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(180deg, rgba(255,255,255,0.5) 0%, transparent 100%);
  pointer-events: none;
}

.tool-grid-icon--pressed {
  transform: scale(0.88);
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.03);
}

.tool-icon-svg {
  width: 40rpx;
  height: 40rpx;
  transition: all 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  position: relative;
  z-index: 1;
}

.tool-icon-svg--pressed {
  transform: scale(1.15) rotate(-6deg);
}

.tool-grid-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.3;
  letter-spacing: -0.3rpx;
  text-align: center;
}

.tool-grid-usage {
  font-size: 20rpx;
  color: rgba(0, 0, 0, 0.4);
  font-weight: 500;
  text-align: center;
  letter-spacing: 0.3rpx;
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
}

.tool-grid-usage::before {
  content: '';
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: var(--accent, #1d5c4b);
  opacity: 0.5;
}

.tool-grid-points {
  font-size: 20rpx;
  color: rgba(0, 0, 0, 0.35);
  font-weight: 500;
  text-align: center;
  letter-spacing: 0.5rpx;
  padding: 4rpx 12rpx;
  background: rgba(255, 255, 255, 0.4);
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.tool-grid-arrow-icon {
  position: absolute;
  right: 18rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 20rpx;
  color: rgba(0, 0, 0, 0.12);
  font-weight: 800;
  transition: all 0.3s ease;
  z-index: 2;
}

.tool-grid-item--pressed .tool-grid-arrow-icon {
  color: rgba(0, 0, 0, 0.25);
  transform: translateY(-50%) translateX(2rpx);
}

.tools-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tool-list-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 10rpx 30rpx rgba(35, 46, 40, 0.06);
