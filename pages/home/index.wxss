}

.member-points-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #d66a4d;
}

.member-points-label {
  font-size: 22rpx;
  color: #7a776d;
}

.member-stats {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.6);
  margin-bottom: 24rpx;
}

.member-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.member-stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e2d29;
}

.member-stat-label {
  font-size: 24rpx;
  color: #7a776d;
}

.member-stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: rgba(29, 92, 75, 0.1);
}

.member-actions {
  display: flex;
  gap: 16rpx;
}

.member-button {
  flex: 1;
}

.container {
  padding-bottom: 240rpx;
}
