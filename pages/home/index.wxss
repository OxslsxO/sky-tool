}

.empty-suggestion-tag {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(29, 92, 75, 0.08);
  font-size: 24rpx;
  color: #1d5c4b;
  transition: background 0.2s ease;
}

.empty-suggestion-tag:active {
  background: rgba(29, 92, 75, 0.15);
}

.task-mini-section {
  margin-top: 32rpx;
}

.task-mini-card {
  display: flex;
