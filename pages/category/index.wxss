.category-focus {
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.92), rgba(245, 242, 235, 0.95));
}

.category-focus__title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2d29;
}

.category-focus__desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #666b64;
}

.category-focus__banner {
  display: block;
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #1d5c4b;
}

.tool-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}
