}

.recent-tool-mini-name {
  font-size: 22rpx;
  color: #636E72;
  font-weight: 600;
  text-align: center;
  max-width: 100rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== з©әзҠ¶жҖҒе»әи®?===== */
.empty-suggestions {
  margin-top: 24rpx;
}

.empty-suggestion-title {
  font-size: 24rpx;
  color: #636E72;
  font-weight: 600;
}

.empty-suggestion-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.empty-suggestion-tag {
  padding: 12rpx 20rpx;
  border-radius: 20rpx 28rpx 20rpx 28rpx;
  background: rgba(200, 149, 108, 0.08);
  color: #C8956C;
  font-size: 24rpx;
  font-weight: 600;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  border: 2rpx solid rgba(200, 149, 108, 0.1);
}

.empty-suggestion-tag:active {
  background: rgba(200, 149, 108, 0.15);
  transform: scale(0.95) translateY(-2rpx);
}

/* ===== з»„еҗҲеҢ?===== */
.bundle-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.bundle-card {
  background: #FFFFFF;
  box-shadow: 0 8rpx 32rpx rgba(200, 149, 108, 0.1);
  border: 2rpx solid rgba(200, 149, 108, 0.06);
}

.bundle-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.bundle-icon-group {
  display: flex;
  gap: -8rpx;
}

.bundle-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx 22rpx 14rpx 22rpx;
  background: linear-gradient(135deg, rgba(200, 149, 108, 0.1) 0%, rgba(253, 203, 110, 0.08) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border: 2rpx solid rgba(200, 149, 108, 0.1);
}

.bundle-tag {
  padding: 8rpx 16rpx;
  border-radius: 16rpx 24rpx 16rpx 24rpx;
  background: rgba(200, 149, 108, 0.1);
  color: #C8956C;
  font-size: 22rpx;
  font-weight: 600;
}

.bundle-title {
  display: block;
  font-size: 30rpx;
