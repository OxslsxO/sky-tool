  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.recent-tool-mini:active {
  transform: scale(0.92);
}

.recent-tool-mini-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx 28rpx 20rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(200, 149, 108, 0.1);
  border: 2rpx solid rgba(200, 149, 108, 0.08);
