<view class="mine-container">
  <view class="mine-header">
    <view class="mine-header-bg">
      <view class="mine-header-glow"></view>
    </view>
    <view class="mine-header-content">
      <view class="mine-avatar">
        <text class="mine-avatar-text">{{user.nickname ? user.nickname[0] : '万'}}</text>
      </view>
      <view class="mine-info">
        <text class="mine-name">{{user.nickname || '万里用户'}}</text>
      </view>
    </view>

    <view class="mine-stats">
      <view class="mine-stat">
        <text class="mine-stat-value">{{user.points}}</text>
        <text class="mine-stat-label">积分</text>
      </view>
      <view class="mine-stat-divider"></view>
      <view class="mine-stat">
        <text class="mine-stat-value">{{taskCount}}</text>
        <text class="mine-stat-label">任务</text>
      </view>
    </view>
  </view>

  <view class="mine-actions">
    <view class="action-card action-card--redeem" bindtap="openRedeemModal">
      <view class="action-card-icon">
        <text>🎁</text>
      </view>
      <view class="action-card-info">
        <text class="action-card-title">口令兑换</text>
        <text class="action-card-desc">输入口令领取积分</text>
      </view>
      <text class="action-card-arrow">›</text>
    </view>
  </view>

  <view class="mine-section" wx:if="{{favorites.length}}">
    <view class="mine-section-head">
      <text class="mine-section-title">我的收藏</text>
    </view>
    <view class="mine-grid">
      <view class="mine-grid-item" wx:for="{{favorites}}" wx:key="id">
        <tool-card tool="{{item}}" compact="{{true}}" bindselect="handleToolSelect" />
      </view>
    </view>
  </view>

  <view class="mine-section" wx:if="{{recents.length}}">
    <view class="mine-section-head">
      <text class="mine-section-title">最近使用</text>
    </view>
    <view class="mine-grid">
      <view class="mine-grid-item" wx:for="{{recents}}" wx:key="id">
        <tool-card tool="{{item}}" compact="{{true}}" bindselect="handleToolSelect" />
      </view>
    </view>
  </view>

  <view class="redeem-overlay" wx:if="{{showRedeemModal}}" catchtap="preventBubble">
    <view class="redeem-modal" catchtap="preventBubble">
      <view class="redeem-modal-close" bindtap="closeRedeemModal">✕</view>
      <view class="redeem-modal-header">
        <text class="redeem-modal-icon">🎁</text>
        <text class="redeem-modal-title">口令兑换</text>
        <text class="redeem-modal-sub">输入口令领取专属福利</text>
      </view>

      <view class="redeem-input-wrapper">
        <input
          class="redeem-input"
          placeholder="请输入口令"
          value="{{redeemInput}}"
          bindinput="onRedeemInput"
          confirm-type="done"
        />
      </view>

      <view class="redeem-modal-buttons">
        <view class="redeem-btn redeem-btn--cancel" bindtap="closeRedeemModal">
          <text>取消</text>
        </view>
        <view class="redeem-btn redeem-btn--confirm {{redeeming ? 'redeem-btn--loading' : ''}}" bindtap="handleRedeem">
          <text>{{redeeming ? '兑换中...' : '确定兑换'}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="mine-footer"></view>
</view>
