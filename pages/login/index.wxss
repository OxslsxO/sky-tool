.login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #fdf6f0 0%, #f5e6d3 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  position: relative;
  overflow: hidden;
}

/* 动态彩虹灯带 + 柔和泛光 */
.rainbow-border {
  position: absolute;
  pointer-events: none;
  z-index: 0;
}

.rainbow-border--top {
  top: 0;
  left: 0;
  right: 0;
  height: 10rpx;
  background: linear-gradient(90deg, #ffb3ba, #ffdfba, #ffffba, #baffc9, #bae1ff, #eecbff, #ffb3ba);
  background-size: 400% 100%;
  animation: rainbow-flow 5s linear infinite;
  filter: blur(3rpx);
  box-shadow:
    0 0 20rpx 4rpx rgba(255, 179, 186, 0.6),
    0 0 60rpx 12rpx rgba(255, 223, 186, 0.4),
    0 0 100rpx 24rpx rgba(186, 225, 255, 0.25);
}

.rainbow-border--top::after {
  content: '';
  position: absolute;
  top: -20rpx;
  left: -10%;
  right: -10%;
  height: 60rpx;
  background: linear-gradient(90deg, rgba(255,179,186,0.3), rgba(255,223,186,0.25), rgba(186,255,201,0.2), rgba(186,225,255,0.25), rgba(238,203,255,0.3));
  background-size: 400% 100%;
  animation: rainbow-flow 5s linear infinite;
  filter: blur(20rpx);
  pointer-events: none;
}

.rainbow-border--right {
  top: 0;
  right: 0;
  bottom: 0;
  width: 10rpx;
  background: linear-gradient(180deg, #ffb3ba, #ffdfba, #ffffba, #baffc9, #bae1ff, #eecbff, #ffb3ba);
  background-size: 100% 400%;
  animation: rainbow-flow-v 5s linear infinite;
  filter: blur(3rpx);
  box-shadow:
    0 0 20rpx 4rpx rgba(255, 179, 186, 0.6),
    0 0 60rpx 12rpx rgba(186, 225, 255, 0.4),
    0 0 100rpx 24rpx rgba(238, 203, 255, 0.25);
}

.rainbow-border--right::after {
  content: '';
  position: absolute;
  top: -10%;
  right: -20rpx;
  bottom: -10%;
  width: 60rpx;
  background: linear-gradient(180deg, rgba(255,179,186,0.3), rgba(255,223,186,0.25), rgba(186,255,201,0.2), rgba(186,225,255,0.25), rgba(238,203,255,0.3));
  background-size: 100% 400%;
  animation: rainbow-flow-v 5s linear infinite;
  filter: blur(20rpx);
  pointer-events: none;
}

.rainbow-border--bottom {
  bottom: 0;
  left: 0;
  right: 0;
  height: 10rpx;
  background: linear-gradient(90deg, #eecbff, #bae1ff, #baffc9, #ffffba, #ffdfba, #ffb3ba, #eecbff);
  background-size: 400% 100%;
  animation: rainbow-flow-reverse 5s linear infinite;
  filter: blur(3rpx);
  box-shadow:
    0 0 20rpx 4rpx rgba(238, 203, 255, 0.6),
    0 0 60rpx 12rpx rgba(186, 225, 255, 0.4),
    0 0 100rpx 24rpx rgba(255, 223, 186, 0.25);
}

.rainbow-border--bottom::after {
  content: '';
  position: absolute;
  bottom: -20rpx;
  left: -10%;
  right: -10%;
  height: 60rpx;
  background: linear-gradient(90deg, rgba(238,203,255,0.3), rgba(186,225,255,0.25), rgba(186,255,201,0.2), rgba(255,255,186,0.25), rgba(255,223,186,0.3));
  background-size: 400% 100%;
  animation: rainbow-flow-reverse 5s linear infinite;
  filter: blur(20rpx);
  pointer-events: none;
}

.rainbow-border--left {
  top: 0;
  left: 0;
  bottom: 0;
  width: 10rpx;
  background: linear-gradient(180deg, #eecbff, #bae1ff, #baffc9, #ffffba, #ffdfba, #ffb3ba, #eecbff);
  background-size: 100% 400%;
  animation: rainbow-flow-v-reverse 5s linear infinite;
  filter: blur(3rpx);
  box-shadow:
    0 0 20rpx 4rpx rgba(238, 203, 255, 0.6),
    0 0 60rpx 12rpx rgba(186, 225, 255, 0.4),
    0 0 100rpx 24rpx rgba(255, 179, 186, 0.25);
}

.rainbow-border--left::after {
  content: '';
  position: absolute;
  top: -10%;
  left: -20rpx;
  bottom: -10%;
  width: 60rpx;
  background: linear-gradient(180deg, rgba(238,203,255,0.3), rgba(186,225,255,0.25), rgba(186,255,201,0.2), rgba(255,255,186,0.25), rgba(255,223,186,0.3));
  background-size: 100% 400%;
  animation: rainbow-flow-v-reverse 5s linear infinite;
  filter: blur(20rpx);
  pointer-events: none;
}

@keyframes rainbow-flow {
  0% { background-position: 0% 50%; }
  100% { background-position: 400% 50%; }
}

@keyframes rainbow-flow-reverse {
  0% { background-position: 400% 50%; }
  100% { background-position: 0% 50%; }
}

@keyframes rainbow-flow-v {
  0% { background-position: 50% 0%; }
  100% { background-position: 50% 400%; }
}

@keyframes rainbow-flow-v-reverse {
  0% { background-position: 50% 400%; }
  100% { background-position: 50% 0%; }
}

.step-content {
  width: 100%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 120rpx;
}

.logo-icon {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fff5e6 0%, #ffd699 50%, #ffb366 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  box-shadow: 0 12rpx 40rpx rgba(255, 179, 102, 0.35), inset 0 0 30rpx rgba(255, 255, 255, 0.4);
  position: relative;
  animation: icon-pulse 3s ease-in-out infinite;
}

.logo-icon::after {
  content: '';
  position: absolute;
  top: -12rpx;
  left: -12rpx;
  right: -12rpx;
  bottom: -12rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(255, 245, 230, 0.5) 0%, rgba(255, 179, 102, 0.5) 100%);
  z-index: -1;
  filter: blur(24rpx);
  animation: glow-pulse 3s ease-in-out infinite;
}

@keyframes icon-pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.03); }
}

@keyframes glow-pulse {
  0%, 100% { opacity: 0.6; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.08); }
}

.logo-icon-inner {
  font-size: 90rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(255, 179, 102, 0.4));
}

.app-name {
  font-size: 52rpx;
  font-weight: bold;
  color: #5d4037;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.app-desc {
  font-size: 28rpx;
  color: #8d6e63;
}

.action-area {
  width: 100%;
  margin-bottom: 60rpx;
}

.wechat-login-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #f4a460 0%, #e07b39 100%);
  color: white;
  border-radius: 50rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(224, 123, 57, 0.35);
  transition: transform 0.2s ease;
}

.wechat-login-btn:active {
  transform: scale(0.98);
}

.btn-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.wechat-login-btn::after {
  border: none;
}

.wechat-login-btn--disabled {
  background: linear-gradient(135deg, #d0d0d0 0%, #a0a0a0 100%);
  box-shadow: 0 4rpx 12rpx rgba(160, 160, 160, 0.2);
  opacity: 0.6;
}

.agree-area {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  justify-content: center;
  margin-bottom: 32rpx;
}

.agree-checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #d0c0b0;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  background: #fff;
}

.agree-checkbox--checked {
  background: linear-gradient(135deg, #f4a460, #e07b39);
  border-color: #e07b39;
}

.agree-checkmark {
  font-size: 24rpx;
  color: #fff;
  font-weight: bold;
}

.agree-text {
  font-size: 24rpx;
  color: #8d6e63;
}

.agree-link {
  font-size: 24rpx;
  color: #e07b39;
  text-decoration: underline;
}

.guest-area {
  margin-top: 20rpx;
}

.guest-link {
  font-size: 26rpx;
  color: #a08070;
}

.user-info-area {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
  padding: 40rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-bottom: 32rpx;
  border: 4rpx solid #e07b39;
  box-shadow: 0 8rpx 20rpx rgba(224, 123, 57, 0.25);
}

.avatar-preview-img {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #ffe0b2 0%, #ffcc80 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-placeholder-icon {
  font-size: 80rpx;
}

.nickname-input-group {
  width: 100%;
}

.nickname-input {
  width: 100%;
  height: 88rpx;
  background: #fafafa;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #5d4037;
  box-sizing: border-box;
}

.nickname-placeholder {
  color: #bdbdbd;
}

.wechat-login-btn--confirm {
  background: linear-gradient(135deg, #4caf50 0%, #388e3c 100%);
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.35);
}

.skip-area {
  width: 100%;
  margin-top: 40rpx;
  display: flex;
  justify-content: center;
}

.skip-btn {
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(10rpx);
  border: 2rpx solid rgba(224, 123, 57, 0.3);
  transition: all 0.2s ease;
}

.skip-btn:active {
  transform: scale(0.98);
  background: rgba(255, 255, 255, 0.8);
}

.skip-text {
  font-size: 28rpx;
  color: #8d6e63;
  font-weight: 500;
}
