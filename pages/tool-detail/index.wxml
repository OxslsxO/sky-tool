<view class="container" wx:if="{{tool}}">
  <view class="hero direct-hero" style="background: {{tool.heroBackground}};">
    <view class="hero-left">
      <text class="hero-title">{{tool.name}}</text>
      <text class="hero-cost" wx:if="{{tool.id !== 'photo-id'}}">{{billing ? billing.costText : (tool.points + ' 积分')}}</text>
    </view>
    <view class="hero-right" wx:if="{{userState}}">
      <view class="user-info">
        <text class="user-info__label">{{userState.memberPlan}}</text>
        <text class="user-info__value" wx:if="{{userState.memberActive}}">有效期至 {{userState.memberExpire}}</text>
        <text class="user-info__value" wx:if="{{!userState.memberActive}}">已过期</text>
      </view>
      <view class="user-info">
        <text class="user-info__label">积分</text>
        <text class="user-info__value">{{userState.points}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <view>
        <text class="eyebrow">Setup</text>
        <text class="section-title">参数</text>
      </view>
    </view>

    <view class="card upload-card">
      <view class="option-block" wx:for="{{tool.params}}" wx:key="key">
        <text class="option-block__title">{{item.label}}</text>
        <view class="chips-wrap {{showMoreColors && item.key === 'background' ? 'chips-wrap-expanded' : ''}}">
          <view
            class="chip {{selections[item.key] === option ? 'chip-active' : ''}} {{item.key === 'background' ? 'chip-color' : ''}}"
            wx:for="{{item.key === 'background' && !showMoreColors ? ['白色', '蓝色', '红色'] : (item.key === 'background' && showMoreColors ? tool.params[1].options : (tool.id === 'image-convert' && item.key === 'target' && imageInput ? convertTargetOptions : item.options))}}"
            wx:for-item="option"
            wx:key="*this"
            data-key="{{item.key}}"
            data-value="{{option}}"
            bindtap="handleOptionSelect"
          >
            <view wx:if="{{item.key === 'background'}}" class="chip-color__dot" style="background: {{backgroundColorMap[option]}};"></view>
            <text>{{option}}</text>
          </view>
          <view
            class="chip chip-expand {{showMoreColors ? 'chip-active' : ''}}"
            wx:if="{{item.key === 'background'}}"
            bindtap="toggleMoreColors"
          >
            <text>{{showMoreColors ? '收起' : '更多'}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{showImageUpload && tool.id !== 'photo-id' && tool.id !== 'image-compress' && tool.id !== 'image-convert'}}">
    <view class="section-head">
      <view>
        <text class="eyebrow">Upload</text>
        <text class="section-title">{{tool.id === 'ocr-text' ? '上传识别图片' : '上传图片'}}</text>
      </view>
    </view>

    <view class="card">
      <view class="btn-ghost picker-button" bindtap="chooseInputImage">{{tool.id === 'image-to-pdf' ? '选择图片（可多选）' : (tool.id === 'ocr-text' ? '选择识别图片' : '选择图片')}}</view>

      <view class="image-preview" wx:if="{{imageInput}}">
        <image class="image-preview__image" src="{{imageInput.path}}" mode="aspectFit"></image>
        <text class="image-preview__meta">尺寸 {{imageInput.width}} × {{imageInput.height}}</text>
        <text class="image-preview__meta">大小 {{imageInput.sizeText}}</text>
      </view>

      <view class="image-preview__list" wx:if="{{tool.id === 'image-to-pdf' && imageInputs.length}}">
        <text class="image-preview__meta">已选择 {{imageInputs.length}} 张图片</text>
        <view class="chips-wrap">
          <text class="chip-static" wx:for="{{imageInputs}}" wx:key="path">第 {{index + 1}} 张 · {{item.width}} × {{item.height}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{tool.id === 'image-compress'}}">
    <view class="section-head">
      <view>
        <text class="eyebrow">Upload</text>
        <text class="section-title">{{compressResultReady ? '压缩结果' : '上传图片'}}</text>
        <text class="section-copy" wx:if="{{compressResultReady}}">{{compressResultDetail}}</text>
      </view>
    </view>

    <view class="card">
      <view class="btn-ghost picker-button" bindtap="chooseInputImage" wx:if="{{!compressResultReady}}">选择图片</view>
      <view class="btn-ghost picker-button" bindtap="chooseInputImage" wx:if="{{compressResultReady}}">重新选择</view>

      <view class="image-preview" wx:if="{{imageInput && !compressResultReady}}">
        <image class="image-preview__image" src="{{imageInput.path}}" mode="aspectFit"></image>
        <text class="image-preview__meta">尺寸 {{imageInput.width}} × {{imageInput.height}}</text>
        <text class="image-preview__meta">大小 {{imageInput.sizeText}}</text>
      </view>

      <view class="image-preview" wx:if="{{compressResultReady}}">
        <image class="image-preview__image" src="{{compressResultPath}}" mode="aspectFit"></image>
        <text class="result-card__title" style="margin-top: 16rpx; text-align: center;">{{compressResultHeadline}}</text>
        <view class="chips-wrap" wx:if="{{compressResultMetaLines.length}}" style="justify-content: center; margin-top: 12rpx;">
          <text class="chip-static" wx:for="{{compressResultMetaLines}}" wx:key="*this">{{item}}</text>
        </view>
        <view class="action-card__buttons" style="margin-top: 24rpx;">
          <view class="btn-primary action-card__button" bindtap="previewCompressResult">预览大图</view>
          <view class="btn-ghost action-card__button" bindtap="saveCompressResult">保存到相册</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{tool.id === 'image-convert'}}">
    <view class="section-head">
      <view>
        <text class="eyebrow">Upload</text>
        <text class="section-title">{{convertResultReady ? '转换结果' : '上传图片'}}</text>
        <text class="section-copy" wx:if="{{convertResultReady}}">{{convertResultDetail}}</text>
      </view>
    </view>

    <view class="card">
      <view class="btn-ghost picker-button" bindtap="chooseInputImage" wx:if="{{!convertResultReady}}">选择图片</view>
      <view class="btn-ghost picker-button" bindtap="chooseInputImage" wx:if="{{convertResultReady}}">重新选择</view>

      <view class="image-preview" wx:if="{{imageInput && !convertResultReady}}">
        <image class="image-preview__image" src="{{imageInput.path}}" mode="aspectFit"></image>
        <text class="image-preview__meta">尺寸 {{imageInput.width}} × {{imageInput.height}}</text>
        <text class="image-preview__meta">大小 {{imageInput.sizeText}}</text>
      </view>

      <view class="image-preview" wx:if="{{convertResultReady}}">
        <image class="image-preview__image" src="{{convertResultPath}}" mode="aspectFit"></image>
        <text class="result-card__title" style="margin-top: 16rpx; text-align: center;">{{convertResultHeadline}}</text>
        <view class="chips-wrap" wx:if="{{convertResultMetaLines.length}}" style="justify-content: center; margin-top: 12rpx;">
          <text class="chip-static" wx:for="{{convertResultMetaLines}}" wx:key="*this">{{item}}</text>
        </view>
        <view class="action-card__buttons" style="margin-top: 24rpx;">
          <view class="btn-primary action-card__button" bindtap="previewConvertResult">预览大图</view>
          <view class="btn-ghost action-card__button" bindtap="saveConvertResult">保存到相册</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{tool.id === 'photo-id'}}">
    <view class="section-head">
      <view>
        <text class="eyebrow">Upload</text>
        <text class="section-title">{{photoIdResultReady ? '生成结果' : '上传照片'}}</text>
        <text class="section-copy" wx:if="{{photoIdResultReady}}">{{photoIdResultDetail}}</text>
      </view>
    </view>

    <view class="card">
      <view class="btn-ghost picker-button" bindtap="chooseInputImage" wx:if="{{!photoIdResultReady}}">选择图片</view>
      <view class="btn-ghost picker-button" bindtap="chooseInputImage" wx:if="{{photoIdResultReady}}">重新选择</view>

      <view class="image-preview" wx:if="{{imageInput && !photoIdResultReady}}">
        <image class="image-preview__image" src="{{imageInput.path}}" mode="aspectFit"></image>
        <text class="image-preview__meta">尺寸 {{imageInput.width}} × {{imageInput.height}}</text>
        <text class="image-preview__meta">大小 {{imageInput.sizeText}}</text>
        <view class="cost-hint" wx:if="{{billing}}">
          <text class="cost-hint__text">{{billing.text}}</text>
        </view>
        <view class="action-card__buttons" style="margin-top: 16rpx;">
          <view class="btn-primary action-card__button {{!imageInput || isWorking ? 'action-card__button-disabled' : ''}}" bindtap="handleExecute">
            <view wx:if="{{isWorking}}" class="loading-wrap">
              <view class="loading-spinner">
                <view class="loading-dot"></view>
                <view class="loading-dot"></view>
                <view class="loading-dot"></view>
              </view>
              <text class="loading-text">处理中</text>
            </view>
            <text wx:else>开始处理</text>
          </view>
        </view>
      </view>

      <view class="image-preview" wx:if="{{photoIdResultReady}}">
        <image class="image-preview__image" src="{{photoIdResultPath}}" mode="aspectFit"></image>
        <text class="result-card__title" style="margin-top: 16rpx; text-align: center;">{{photoIdResultHeadline}}</text>
        <view class="chips-wrap" wx:if="{{photoIdResultMetaLines.length}}" style="justify-content: center; margin-top: 12rpx;">
          <text class="chip-static" wx:for="{{photoIdResultMetaLines}}" wx:key="*this">{{item}}</text>
        </view>
        <view class="action-card__buttons" style="margin-top: 24rpx;">
          <view class="btn-primary action-card__button" bindtap="previewPhotoIdResult">预览大图</view>
          <view class="btn-ghost action-card__button" bindtap="savePhotoIdResult">保存到相册</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{showBackendFilePicker}}">
    <view class="section-head">
      <view>
        <text class="eyebrow">Files</text>
        <text class="section-title">{{pdfToWordResultReady ? '转换结果' : backendPickerTitle}}</text>
        <text class="section-copy" wx:if="{{pdfToWordResultReady}}">{{pdfToWordResultDetail}}</text>
      </view>
    </view>

    <view class="card">
      <view class="btn-ghost picker-button" bindtap="chooseBackendFiles" wx:if="{{!pdfToWordResultReady}}">{{backendPickerButtonText}}</view>
      <view class="btn-ghost picker-button" bindtap="chooseBackendFiles" wx:if="{{pdfToWordResultReady}}">重新选择</view>

      <view class="file-list" wx:if="{{backendFiles.length && !pdfToWordResultReady}}">
        <view class="file-item" wx:for="{{backendFiles}}" wx:key="path">
          <text class="file-item__name">{{item.name}}</text>
          <text class="file-item__meta">{{item.sizeText}}</text>
        </view>
      </view>

      <view class="image-preview" wx:if="{{pdfToWordResultReady}}">
        <view class="file-preview">
          <text class="file-preview__icon">📄</text>
          <text class="file-preview__name">{{pdfToWordResultName}}</text>
        </view>
        <text class="result-card__title" style="margin-top: 16rpx; text-align: center;">{{pdfToWordResultHeadline}}</text>
        <view class="chips-wrap" wx:if="{{pdfToWordResultMetaLines.length}}" style="justify-content: center; margin-top: 12rpx;">
          <text class="chip-static" wx:for="{{pdfToWordResultMetaLines}}" wx:key="*this">{{item}}</text>
        </view>
        <view class="action-card__buttons" style="margin-top: 24rpx;">
          <view class="btn-primary action-card__button" bindtap="downloadPdfToWordResult">下载文件</view>
          <view class="btn-ghost action-card__button" wx:if="{{pdfToWordResultRemoteUrl}}" bindtap="copyPdfToWordUrl">复制链接</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{showBackendRangeInput}}">
    <view class="section-head">
      <view>
        <text class="eyebrow">Range</text>
        <text class="section-title">输入页码范围</text>
      </view>
    </view>

    <view class="card form-card">
      <input class="field-input" value="{{pageRange}}" bindinput="handlePageRangeInput" placeholder="例如 1-3,5,8-10" />
    </view>
  </view>

  <view class="section" wx:if="{{showCustomSize}}">
    <view class="section-head">
      <view>
        <text class="eyebrow">Custom</text>
        <text class="section-title">输入自定义尺寸</text>
      </view>
    </view>

    <view class="card form-card">
      <input class="field-input" type="number" value="{{customWidth}}" bindinput="handleCustomWidth" placeholder="宽度" />
      <input class="field-input" type="number" value="{{customHeight}}" bindinput="handleCustomHeight" placeholder="高度" />
    </view>
  </view>

  <view class="section" wx:if="{{showTextInput}}">
    <view class="section-head">
      <view>
        <text class="eyebrow">Content</text>
        <text class="section-title">输入二维码内容</text>
      </view>
    </view>

    <view class="card">
      <textarea class="text-area" maxlength="-1" value="{{textInput}}" bindinput="handleTextInput" placeholder="输入链接、文本、联系方式等内容" />
      <view class="qr-logo-row">
        <view class="btn-ghost qr-logo-button" bindtap="chooseQrLogo">{{qrLogoInput ? '更换 Logo' : '上传 Logo'}}</view>
        <view class="btn-ghost qr-logo-button" wx:if="{{qrLogoInput}}" bindtap="removeQrLogo">移除</view>
      </view>
      <view class="qr-logo-preview" wx:if="{{qrLogoInput}}">
        <image class="qr-logo-preview__image" src="{{qrLogoInput.path}}" mode="aspectFill"></image>
        <text class="qr-logo-preview__meta">{{qrLogoInput.width}} × {{qrLogoInput.height}} · {{qrLogoInput.sizeText}}</text>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{showUnitConverter}}">
    <view class="section-head">
      <view>
        <text class="eyebrow">Convert</text>
        <text class="section-title">输入换算数值</text>
      </view>
    </view>

    <view class="card form-card">
      <input class="field-input" type="digit" value="{{numberInput}}" bindinput="handleNumberInput" placeholder="输入数值" />
      <picker range="{{unitOptions}}" bindchange="handleUnitChange" data-field="fromUnit">
        <view class="picker-line">从：{{fromUnit}}</view>
      </picker>
      <picker range="{{unitOptions}}" bindchange="handleUnitChange" data-field="toUnit">
        <view class="picker-line">到：{{toUnit}}</view>
      </picker>
      <view class="btn-ghost picker-button" bindtap="swapUnits">交换单位</view>
    </view>
  </view>

  <view class="section" wx:if="{{tool.id !== 'photo-id'}}">
    <view class="card action-card">
      <text class="action-card__title">{{actionTitle}}</text>
      <text class="action-card__copy">{{billing ? billing.text : ''}}</text>
      <text class="action-card__hint" wx:if="{{actionHint}}">{{actionHint}}</text>

      <view class="action-card__buttons">
        <view class="btn-primary action-card__button {{primaryActionDisabled || isWorking ? 'action-card__button-disabled' : ''}}" bindtap="handleExecute">
          <view wx:if="{{isWorking}}" class="loading-wrap">
            <view class="loading-spinner">
              <view class="loading-dot"></view>
              <view class="loading-dot"></view>
              <view class="loading-dot"></view>
            </view>
            <text class="loading-text">处理中</text>
          </view>
          <text wx:else>{{primaryActionText}}</text>
        </view>
        <view class="btn-ghost action-card__button" bindtap="handleFavorite">{{favorite ? '取消收藏' : '收藏工具'}}</view>
      </view>
    </view>
  </view>







  <view class="section" wx:if="{{showRecentTasks && relatedTasks.length}}">
    <view class="section-head">
      <view>
        <text class="eyebrow">Recent</text>
        <text class="section-title">最近处理记录</text>
      </view>
    </view>

    <view class="related-list">
      <view class="card related-card" wx:for="{{relatedTasks}}" wx:key="id" data-id="{{item.id}}" bindtap="openTask">
        <view class="row space-between">
          <text class="related-card__title">{{item.statusText}}</text>
          <text class="related-card__time">{{item.createdLabel}}</text>
        </view>
        <text class="related-card__copy">{{item.finalDetail || item.resultHeadline}}</text>
      </view>
    </view>
  </view>

  <canvas
    canvas-id="toolCanvas"
    class="tool-canvas"
    style="width: {{canvasWidth}}px; height: {{canvasHeight}}px;"
  ></canvas>

  <view wx:if="{{showProcessingOverlay}}" class="processing-overlay">
    <view class="processing-panel">
      <view class="processing-spinner">
        <view class="processing-spinner__ring"></view>
        <view class="processing-spinner__ring processing-spinner__ring--second"></view>
      </view>
      <text class="processing-title">证件照处理中</text>
      <text class="processing-status">{{processingStatus}}</text>
      <view class="processing-progress-wrap">
        <view class="processing-progress-track">
          <view class="processing-progress-fill" style="width: {{processingProgress}}%;"></view>
        </view>
        <text class="processing-progress-text">{{processingProgress}}%</text>
      </view>
    </view>
  </view>
</view>
