/* ===== VIP 页面 - 温馨创新风格 ===== */

.vip-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #fff8f0 0%, #fffaf5 30%, #fdf8f3 100%);
  padding: 0 28rpx 40rpx;
}

/* ===== 顶部状态卡片 ===== */
.vip-header {
  position: relative;
  margin: 0 -28rpx;
  padding: 48rpx 28rpx 60rpx;
  overflow: hidden;
}

.vip-header-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #f5e6d3 0%, #f0dcc8 40%, #e8d4c0 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.vip-header-glow {
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255, 220, 180, 0.6) 0%, transparent 70%);
}

.vip-header-content {
  position: relative;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 状态信息 */
.vip-status {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.vip-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  width: fit-content;
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #c4783a, #d4956a);
  border-radius: 999rpx;
  box-shadow: 0 4rpx 16rpx rgba(196, 120, 58, 0.25);
}

.vip-badge--inactive {
  background: linear-gradient(135deg, #b8a898, #c4b8a8);
  box-shadow: 0 4rpx 16rpx rgba(160, 140, 120, 0.2);
}

.vip-badge-icon {
  font-size: 24rpx;
}

.vip-badge-text {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
}

.vip-plan-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #5a3d2b;
}

.vip-expire {
  font-size: 24rpx;
  color: #8a7060;
}

/* 积分圆环 */
.vip-points {
  display: flex;
  align-items: center;
}

.points-ring {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.9), rgba(255, 250, 245, 0.8));
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  box-shadow:
    0 8rpx 32rpx rgba(160, 120, 80, 0.15),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.8);
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.points-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #c4783a;
  line-height: 1;
}

.points-label {
  font-size: 20rpx;
  color: #b8a898;
}

/* ===== 标签切换 ===== */
.vip-tabs {
  display: flex;
  gap: 16rpx;
  margin: 32rpx 0 28rpx;
}

.vip-tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 0;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #a89888;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
}

.vip-tab-icon {
  font-size: 36rpx;
  transition: all 0.3s ease;
}

.vip-tab-active {
  background: linear-gradient(135deg, #fff5e8, #ffe8d0);
  color: #c4783a;
  font-weight: 600;
  border-color: rgba(196, 120, 58, 0.15);
  box-shadow: 0 4rpx 16rpx rgba(196, 120, 58, 0.1);
}

.vip-tab-active .vip-tab-icon {
  transform: scale(1.15);
}

/* ===== 区块标题 ===== */
.section-title {
  margin-bottom: 24rpx;
}

.section-title-text {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #5a3d2b;
  margin-bottom: 8rpx;
}

.section-title-sub {
  display: block;
  font-size: 24rpx;
  color: #a89888;
}

/* ===== 卡片列表 ===== */
.plan-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* ===== 会员卡片 ===== */
.plan-card {
  position: relative;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.95), rgba(250, 245, 238, 0.9));
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(160, 120, 80, 0.06);
  border: 2rpx solid rgba(230, 210, 190, 0.3);
  transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  overflow: hidden;
}

.plan-card:active {
  transform: scale(0.98);
}

.plan-card--recommended {
  background: linear-gradient(145deg, rgba(255, 248, 240, 0.98), rgba(255, 242, 230, 0.95));
  border-color: rgba(232, 168, 124, 0.4);
}

.plan-card--selected {
  border-color: #e8a87c;
  box-shadow: 0 8rpx 32rpx rgba(196, 120, 58, 0.12);
  transform: translateX(-4rpx);
}

.plan-card-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

/* 左侧信息 */
.plan-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.plan-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.plan-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #5a3d2b;
}

.plan-badge {
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #e8a87c, #d4956a);
  border-radius: 999rpx;
}

.plan-badge text {
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
}

.plan-price-row {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.plan-price {
  font-size: 44rpx;
  font-weight: 700;
  color: #c4783a;
  line-height: 1.2;
}

.plan-period {
  font-size: 24rpx;
  color: #a89888;
}

.plan-desc {
  font-size: 22rpx;
  color: #a89888;
  line-height: 1.5;
}

/* ===== 右侧购买按钮 - 选中时弹出 ===== */
.plan-action {
  width: 0;
  overflow: hidden;
  opacity: 0;
  transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  display: flex;
  align-items: center;
}

.plan-action--show {
  width: 120rpx;
  opacity: 1;
}

.buy-btn {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e8a87c, #c4783a);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 4rpx 16rpx rgba(196, 120, 58, 0.3),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.3);
  overflow: hidden;
}

.buy-btn--points {
  background: linear-gradient(135deg, #e8c07c, #c4953a);
  box-shadow:
    0 4rpx 16rpx rgba(196, 149, 58, 0.3),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.3);
}

.buy-btn-text {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  z-index: 1;
}

/* 按钮光泽动画 */
.buy-btn-shine {
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    45deg,
    transparent 30%,
    rgba(255, 255, 255, 0.2) 50%,
    transparent 70%
  );
  animation: shine 3s ease-in-out infinite;
}

@keyframes shine {
  0%, 100% { transform: translateX(-100%) rotate(45deg); }
  50% { transform: translateX(100%) rotate(45deg); }
}

.buy-btn--loading {
  opacity: 0.7;
}

/* 选中装饰线 */
.plan-selected-line {
  position: absolute;
  left: 0;
  top: 20%;
  bottom: 20%;
  width: 4rpx;
  background: linear-gradient(180deg, #e8a87c, #c4783a);
  border-radius: 2rpx;
}

/* ===== 积分卡片 ===== */
.points-card {
  position: relative;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.95), rgba(250, 245, 238, 0.9));
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(160, 120, 80, 0.06);
  border: 2rpx solid rgba(230, 210, 190, 0.3);
  transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  overflow: hidden;
}

.points-card:active {
  transform: scale(0.98);
}

.points-card--selected {
  border-color: #e8c07c;
  box-shadow: 0 8rpx 32rpx rgba(196, 149, 58, 0.12);
  transform: translateX(-4rpx);
}

.points-bonus {
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, #e8c07c, #d4a56a);
  border-radius: 999rpx;
}

.points-bonus text {
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
}

/* ===== 记录列表 ===== */
.records-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 80rpx 0;
}

.records-empty-icon {
  font-size: 64rpx;
  opacity: 0.5;
}

.records-empty-text {
  font-size: 28rpx;
  color: #b8a898;
}

.records-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 20rpx;
  border: 1rpx solid rgba(230, 210, 190, 0.2);
}

.record-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.record-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: rgba(230, 210, 190, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.record-icon--plus {
  background: linear-gradient(135deg, rgba(232, 168, 124, 0.2), rgba(196, 120, 58, 0.15));
}

.record-icon--minus {
  background: linear-gradient(135deg, rgba(214, 106, 77, 0.15), rgba(180, 80, 50, 0.1));
}

.record-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.record-title {
  font-size: 28rpx;
  color: #5a3d2b;
  font-weight: 500;
}

.record-time {
  font-size: 22rpx;
  color: #a89888;
}

.record-change {
  font-size: 32rpx;
  font-weight: 700;
}

.record-plus {
  color: #c4783a;
}

.record-minus {
  color: #d66a4d;
}

.record-zero {
  color: #a89888;
}

/* ===== 底部留白 ===== */
.vip-footer {
  height: 40rpx;
}
