page {
  min-height: 100%;
  background:
    linear-gradient(180deg, #f7f3ea 0%, #f1ede4 32%, #fbfaf6 100%);
  color: #1d2421;
  font-family: "Avenir Next", "PingFang SC", "Microsoft YaHei", sans-serif;
}

.container {
  padding: 28rpx 28rpx 136rpx;
  box-sizing: border-box;
}

.hero {
  position: relative;
  overflow: hidden;
  border-radius: 34rpx;
  padding: 34rpx;
  background: linear-gradient(145deg, #efe1d5 0%, #f8f4ee 58%, #ffffff 100%);
  box-shadow: 0 18rpx 50rpx rgba(35, 46, 40, 0.08);
}

.hero::after {
  content: "";
  position: absolute;
  right: -48rpx;
  top: -52rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.34);
}

.eyebrow {
  display: block;
  font-size: 22rpx;
  line-height: 1.2;
  letter-spacing: 4rpx;
  color: #7f7a70;
  text-transform: uppercase;
}

.hero-title {
  display: block;
  margin-top: 16rpx;
  font-size: 46rpx;
  line-height: 1.28;
  font-weight: 700;
  color: #1e2d29;
}

.hero-copy {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #5a625e;
}

.hero-stat-row {
  position: relative;
  z-index: 2;
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
  flex-wrap: wrap;
}

.hero-stat {
  min-width: 156rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.68);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.hero-stat-value {
  display: block;
  font-size: 32rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #1d5c4b;
}

.hero-stat-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: #71756d;
}

.section {
  margin-top: 32rpx;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  margin-top: 8rpx;
  font-size: 38rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #1e2d29;
}

.section-copy {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #75736b;
}

.section-link {
  flex-shrink: 0;
  font-size: 24rpx;
  line-height: 1.2;
  color: #1d5c4b;
}

.card {
  border-radius: 30rpx;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 16rpx 48rpx rgba(35, 46, 40, 0.07);
  box-sizing: border-box;
}

.subtle-card {
  background: rgba(255, 255, 255, 0.62);
  border: 1rpx solid rgba(228, 221, 208, 0.9);
}

.chip-row,
.chips-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.chip {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(44, 62, 55, 0.1);
  background: rgba(255, 255, 255, 0.84);
  font-size: 24rpx;
  line-height: 1.2;
  color: #5d6158;
}

.chip-active {
  border-color: #1d5c4b;
  background: #1d5c4b;
  color: #ffffff;
}

.chip-static {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(29, 92, 75, 0.08);
  color: #1d5c4b;
  font-size: 24rpx;
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(29, 92, 75, 0.1);
  color: #1d5c4b;
  font-size: 22rpx;
  line-height: 1.2;
}

.pill-soft {
  background: rgba(214, 106, 77, 0.12);
  color: #b85a3f;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.7);
  color: #5a5e56;
  font-size: 22rpx;
}

.btn-primary,
.btn-secondary,
.btn-ghost {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 92rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  line-height: 1.2;
  box-sizing: border-box;
}

.btn-primary {
  background: linear-gradient(135deg, #1d5c4b 0%, #3c7d68 100%);
  color: #ffffff;
  box-shadow: 0 16rpx 34rpx rgba(29, 92, 75, 0.24);
}

.btn-secondary {
  background: linear-gradient(135deg, #d66a4d 0%, #e89a5f 100%);
  color: #ffffff;
  box-shadow: 0 16rpx 34rpx rgba(214, 106, 77, 0.22);
}

.btn-ghost {
  border: 1rpx solid rgba(29, 92, 75, 0.16);
  background: rgba(255, 255, 255, 0.76);
  color: #1d5c4b;
}

.muted {
  color: #79776f;
}

.row {
  display: flex;
  align-items: center;
}

.space-between {
  justify-content: space-between;
}

.grid-two {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.grid-item {
  width: calc(50% - 9rpx);
}

.progress-shell {
  margin-top: 18rpx;
}

.progress-track {
  width: 100%;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(29, 92, 75, 0.12);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #1d5c4b 0%, #4c8b76 100%);
}

.progress-text {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #6d7268;
}

.metric-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.metric-card {
  flex: 1;
  min-width: 180rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(248, 246, 241, 0.92);
}

.metric-label {
  display: block;
  font-size: 22rpx;
  color: #7a776d;
}

.metric-value {
  display: block;
  margin-top: 8rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #1e2d29;
}

.empty-state {
  padding: 44rpx 26rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2c28;
}

.empty-copy {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #76736a;
}
