.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 140rpx;
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  padding-bottom: calc(env(safe-area-inset-bottom) + 20rpx);
  z-index: 999;
  padding-left: 30rpx;
  padding-right: 30rpx;
}

.tab-bar-bg {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  right: 20rpx;
  bottom: calc(env(safe-area-inset-bottom) + 10rpx);
  background: #f5f5f5;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.tab-bar-item {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  margin-bottom: 10rpx;
  transition: all 0.3s ease;
}

/* 选中状态的白色凸起卡片 */
.tab-bar-item.active {
  transform: translateY(-10rpx);
}

.tab-bar-item.active::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 120rpx;
  height: 100rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 
    0 8rpx 24rpx rgba(0, 0, 0, 0.12),
    0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  z-index: 0;
}

.tab-icon {
  font-size: 44rpx;
  margin-bottom: 6rpx;
  z-index: 1;
  transition: all 0.3s ease;
}

.tab-text {
  font-size: 22rpx;
  color: #999999;
  z-index: 1;
  transition: all 0.3s ease;
}

/* 选中状态 */
.tab-bar-item.active .tab-icon {
  transform: scale(1.1);
}

.tab-bar-item.active .tab-text {
  color: #333333;
  font-weight: 500;
}

/* 未选中状态 */
.tab-bar-item:not(.active):active {
  opacity: 0.7;
}
