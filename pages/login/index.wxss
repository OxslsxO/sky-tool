.login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f7fa 0%, #e4e8ec 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
}

.step-content {
  width: 100%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 120rpx;
}

.logo-text {
  font-size: 160rpx;
  margin-bottom: 30rpx;
}

.success-icon {
  animation: popIn 0.3s ease-out;
}

@keyframes popIn {
  0% { transform: scale(0.5); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.app-desc {
  font-size: 28rpx;
  color: #666;
}

.action-area {
  width: 100%;
  margin-bottom: 60rpx;
}

.wechat-login-btn,
.phone-bind-btn {
  width: 100%;
  height: 100rpx;
  background: #07c160;
  color: white;
  border-radius: 50rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.25);
}

.btn-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.wechat-login-btn::after,
.phone-bind-btn::after {
  border: none;
}

.test-hint {
  margin-top: 24rpx;
  text-align: center;
}

.test-text {
  font-size: 26rpx;
  color: #999;
  text-decoration: underline;
}

.bottom-tip {
  text-align: center;
}

.tip-text {
  font-size: 24rpx;
  color: #999;
}
