  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.06);
  border: 2rpx solid rgba(255,255,255,0.5);
}

.tool-list-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.tool-list-header {
