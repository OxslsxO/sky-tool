.bundle-action {
  font-size: 24rpx;
  color: #1d5c4b;
  font-weight: 500;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.member-card {
  background: linear-gradient(145deg, #e8efe9 0%, #f7faf8 62%, #ffffff 100%);
  margin-bottom: 30rpx;
}

.member-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.member-avatar-shell {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1d5c4b 0%, #3c7d68 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
}

.member-avatar {
