.tasks-hero {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 36rpx;
  transform: none;
}

.tasks-hero .eyebrow {
  font-size: 18rpx;
}

.tasks-hero .hero-title {
  font-size: 32rpx;
  margin-top: 6rpx;
  text-shadow: none;
}

.tasks-hero .hero-stat-row {
  margin-top: 0;
  flex-shrink: 0;
}

.tasks-hero .hero-stat {
  padding: 12rpx 20rpx;
  min-width: auto;
}

.tasks-hero .hero-stat-value {
  font-size: 28rpx;
}

.tasks-hero .hero-stat-label {
  font-size: 20rpx;
  margin-top: 2rpx;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.task-card__left {
  display: flex;
  flex-direction: column;
}

.task-card__tool {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2d29;
}

.task-card__time {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7a776d;
}

.task-card__status {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.task-card__status--processing {
  background: rgba(29, 92, 75, 0.1);
  color: #1d5c4b;
}

.task-card__status--success {
  background: rgba(84, 128, 105, 0.12);
  color: #3f725a;
}

.task-card__status--failed {
  background: rgba(214, 106, 77, 0.12);
  color: #bb5f42;
}

.task-card__headline {
  display: block;
  margin-top: 20rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2b28;
}

.task-card__detail {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #666a63;
}

.task-card__metrics {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 18rpx;
  font-size: 22rpx;
  color: #6d7268;
}

.empty-button {
  margin-top: 24rpx;
}

.load-more {
  display: flex;
  justify-content: center;
  padding: 28rpx 0 12rpx;
}

.load-more__text {
  font-size: 24rpx;
  color: #b0a090;
}

.load-more--end .load-more__text {
  color: #ccc5bc;
}
