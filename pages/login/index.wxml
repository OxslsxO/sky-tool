<view class="login-container">
  <view class="rainbow-border rainbow-border--top"></view>
  <view class="rainbow-border rainbow-border--right"></view>
  <view class="rainbow-border rainbow-border--bottom"></view>
  <view class="rainbow-border rainbow-border--left"></view>

  <view class="step-content">
    <view class="logo-area">
      <view class="logo-icon">
        <text class="logo-icon-inner">🌟</text>
      </view>
      <text class="app-name">万里工具箱</text>
      <text class="app-desc">温暖实用的多功能工具集</text>
    </view>

    <view class="user-info-area" wx:if="{{showUserInfoStep}}">
      <view class="avatar-preview">
        <image wx:if="{{avatarUrl}}" class="avatar-preview-img" src="{{avatarUrl}}" mode="aspectFill" />
        <view wx:else class="avatar-placeholder">
          <text class="avatar-placeholder-icon">👤</text>
        </view>
      </view>
      <view class="nickname-input-group">
        <input
          class="nickname-input"
          type="nickname"
          placeholder="请输入昵称"
          value="{{nickname}}"
          bindinput="onNicknameInput"
          placeholder-class="nickname-placeholder"
        />
      </view>
    </view>

    <view class="action-area">
      <button
        wx:if="{{!showUserInfoStep}}"
        class="wechat-login-btn"
        open-type="chooseAvatar"
        bind:chooseavatar="onChooseAvatar"
        loading="{{loading}}"
      >
        <text class="btn-icon">💬</text>
        选择头像
      </button>
      <button
        wx:else
        class="wechat-login-btn wechat-login-btn--confirm"
        bindtap="onConfirmLogin"
        loading="{{loading}}"
      >
        确认登录
      </button>
    </view>

    <view class="bottom-tip">
      <text class="tip-text">登录即表示同意用户协议和隐私政策</text>
    </view>
  </view>
</view>
